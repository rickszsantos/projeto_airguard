<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AirGuard - Configurações</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/configuracao.css">
</head>
<body>
<div class="layout">

    <!-- ── Sidebar ── -->
    <nav class="sidebar">
        <div class="sidebar-logo">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                <rect width="36" height="36" rx="10" fill="rgba(255,255,255,0.18)"/>
                <path d="M18 8 L26 12 L26 20 C26 24.4 22.4 28 18 29 C13.6 28 10 24.4 10 20 L10 12 Z" fill="white" opacity="0.9"/>
                <ellipse cx="18" cy="16" rx="6" ry="4" fill="#2563eb" opacity="0.7"/>
                <path d="M12 20 Q18 24 24 20" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            </svg>
            <span class="sidebar-logo-text">AirGuard</span>
        </div>

        <a href="/home" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><path d="M9 21V12h6v9"/>
            </svg>
            Dashboard
        </a>
        <a href="/historico" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>
            </svg>
            Histórico
        </a>
        <a href="/sensores" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
            Sensores
        </a>
        <a href="/configuracoes" class="nav-item active">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
            </svg>
            Configurações
        </a>

        <div class="sidebar-footer">
            <div class="footer-status">
                <span class="dot-green"></span>
                <span>Sistema Online</span>
            </div>
            <div class="footer-quality">
                Qualidade do Ar: <strong>Boa</strong>
                <span class="check-circle">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </span>
            </div>
        </div>
    </nav>

    <!-- ── Main ── -->
    <div class="main">




        <header class="top-header">
            <h1>AirGuard — Monitoramento</h1>
            <div class="header-right">
                <div class="notif-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 01-3.46 0"/>
                    </svg>
                   
                </div>
                <div class="user-info">
                    <div class="user-avatar">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                    </div>
                    <span>Admin</span>
                    <span class="user-badge">ADM</span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
            </div>
        </header>



        

        <div class="content">

            <!-- Page title -->
            <div class="page-top">
                <h2 class="page-title">Configurações</h2>
                <p class="page-sub">Gerencie as configurações do sistema e das estações.</p>
            </div>

            <!-- Abas -->
            <div class="tabs-bar">
                <button class="tab active" onclick="mudarAba('sistema', this)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                    Sistema
                </button>
                <button class="tab" onclick="mudarAba('estacoes', this)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
                    Estações
                </button>
                <button class="tab" onclick="mudarAba('sensores', this)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1114 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2"/></svg>
                    Sensores
                </button>
                <button class="tab" onclick="mudarAba('perfil', this)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Perfil
                </button>
            </div>

            <!-- ── ABA SISTEMA ── -->
            <div id="aba-sistema" class="aba-content">
                <div class="cards-grid">

                    <!-- Configurações do Sistema -->
                    <div class="config-card">
                        <h3 class="card-title">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                            Configurações do Sistema
                        </h3>
                        <div class="config-row">
                            <div class="config-info">
                                <span class="config-label">Intervalo global de leitura</span>
                                <span class="config-desc">Tempo entre leituras dos sensores (padrão)</span>
                            </div>
                            <select class="config-select">
                                <option>5 segundos</option>
                                <option>10 segundos</option>
                                <option>30 segundos</option>
                                <option>1 minuto</option>
                            </select>
                        </div>
                        <div class="config-row">
                            <div class="config-info">
                                <span class="config-label">Fuso horário</span>
                                <span class="config-desc">Selecione o fuso horário do sistema</span>
                            </div>
                            <select class="config-select">
                                <option>America/Sao_Paulo</option>
                                <option>America/Manaus</option>
                                <option>America/Belem</option>
                            </select>
                        </div>
                        <div class="config-row">
                            <div class="config-info">
                                <span class="config-label">Unidade de temperatura</span>
                                <span class="config-desc">Unidade padrão para exibição de temperatura</span>
                            </div>
                            <select class="config-select">
                                <option>°C</option>
                                <option>°F</option>
                            </select>
                        </div>
                        <div class="config-row">
                            <div class="config-info">
                                <span class="config-label">Unidade de concentração</span>
                                <span class="config-desc">Unidade padrão para gases</span>
                            </div>
                            <select class="config-select">
                                <option>ppm</option>
                                <option>ppb</option>
                                <option>mg/m³</option>
                            </select>
                        </div>
                        <div class="card-footer">
                            <button class="btn-salvar">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                                Salvar Alterações
                            </button>
                        </div>
                    </div>

                    <!-- Notificações e Alertas -->
                    <div class="config-card">
                        <h3 class="card-title">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
                            Notificações e Alertas
                        </h3>
                        <div class="toggle-row">
                            <div class="config-info">
                                <span class="config-label">Alertas por e-mail</span>
                                <span class="config-desc">Receber alertas por e-mail</span>
                            </div>
                            <label class="toggle">
                                <input type="checkbox" checked onchange="this.closest('.toggle').classList.toggle('on', this.checked)">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="toggle-row">
                            <div class="config-info">
                                <span class="config-label">Alertas no sistema</span>
                                <span class="config-desc">Exibir alertas no painel</span>
                            </div>
                            <label class="toggle">
                                <input type="checkbox" checked onchange="this.closest('.toggle').classList.toggle('on', this.checked)">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="toggle-row">
                            <div class="config-info">
                                <span class="config-label">Níveis críticos</span>
                                <span class="config-desc">Notificar quando valores atingirem níveis críticos</span>
                            </div>
                            <label class="toggle">
                                <input type="checkbox" checked onchange="this.closest('.toggle').classList.toggle('on', this.checked)">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="toggle-row">
                            <div class="config-info">
                                <span class="config-label">Resumo diário</span>
                                <span class="config-desc">Receber resumo diário por e-mail</span>
                            </div>
                            <label class="toggle">
                                <input type="checkbox" onchange="this.closest('.toggle').classList.toggle('on', this.checked)">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="card-footer">
                            <button class="btn-salvar">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                                Salvar Alterações
                            </button>
                        </div>
                    </div>

                    <!-- Backup e Manutenção -->
                    <div class="config-card" style="grid-column: 1 / -1;" ></div>
                        <h3 class="card-title">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                            Backup e Manutenção
                        </h3>
                        <div class="toggle-row">
                            <div class="config-info">
                                <span class="config-label">Backup automático</span>
                                <span class="config-desc">Realizar backup automático do banco de dados</span>
                            </div>
                            <label class="toggle on">
                                <input type="checkbox" checked onchange="this.closest('.toggle').classList.toggle('on', this.checked)">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="config-row">
                            <div class="config-info">
                                <span class="config-label">Frequência do backup</span>
                                <span class="config-desc">Defina a frequência dos backups automáticos</span>
                            </div>
                            <select class="config-select">
                                <option>Diário</option>
                                <option>Semanal</option>
                                <option>Mensal</option>
                            </select>
                        </div>
                        <div class="config-row">
                            <div class="config-info">
                                <span class="config-label">Limpeza de dados antigos</span>
                                <span class="config-desc">Remover dados antigos automaticamente</span>
                            </div>
                            <select class="config-select">
                                <option>90 dias</option>
                                <option>180 dias</option>
                                <option>1 ano</option>
                                <option>Nunca</option>
                            </select>
                        </div>
                        <div class="card-footer">
                            <button class="btn-salvar">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                                Salvar Alterações
                            </button>
                        </div>
                    </div>

                </div>
            </div>

            <!-- ── ABA ESTAÇÕES ── -->
            <div id="aba-estacoes" class="aba-content" style="display:none">
                <div class="config-card" style="max-width:100%">
                    <h3 class="card-title">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
                        Gerenciar Estações
                    </h3>
                    <p style="color:#64748b; font-size:13px; font-weight:600; padding: 16px 0;">Acesse a página de <a href="/sensores" style="color:#2563eb; font-weight:800;">Sensores</a> para gerenciar suas estações.</p>
                </div>
            </div>

            <!-- ── ABA SENSORES ── -->
            <div id="aba-sensores" class="aba-content" style="display:none">
                <div class="config-card" style="max-width:100%">
                    <h3 class="card-title">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1114 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2"/></svg>
                        Configurar Sensores
                    </h3>
                    <div class="config-row">
                        <div class="config-info">
                            <span class="config-label">Sensor MQ-7 (CO)</span>
                            <span class="config-desc">Limite de alerta para monóxido de carbono</span>
                        </div>
                        <input type="number" value="50" class="config-input" placeholder="ppm"/>
                    </div>
                    <div class="config-row">
                        <div class="config-info">
                            <span class="config-label">Sensor MQ-135 (Gases)</span>
                            <span class="config-desc">Limite de alerta para qualidade do ar</span>
                        </div>
                        <input type="number" value="400" class="config-input" placeholder="ppm"/>
                    </div>
                    <div class="config-row">
                        <div class="config-info">
                            <span class="config-label">DHT22 — Temperatura máxima</span>
                            <span class="config-desc">Limite de alerta para temperatura</span>
                        </div>
                        <input type="number" value="40" class="config-input" placeholder="°C"/>
                    </div>
                    <div class="config-row">
                        <div class="config-info">
                            <span class="config-label">DHT22 — Umidade mínima</span>
                            <span class="config-desc">Limite de alerta para umidade relativa</span>
                        </div>
                        <input type="number" value="20" class="config-input" placeholder="%"/>
                    </div>
                    <div class="card-footer">
                        <button class="btn-salvar">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Salvar Alterações
                        </button>
                    </div>
                </div>
            </div>

            <!-- ── ABA PERFIL ── -->
            <div id="aba-perfil" class="aba-content" style="display:none">
                <div class="config-card" style="max-width:600px">
                    <h3 class="card-title">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Perfil do Usuário
                    </h3>
                    <div class="config-row">
                        <div class="config-info">
                            <span class="config-label">Nome</span>
                            <span class="config-desc">Seu nome de exibição</span>
                        </div>
                        <input type="text" class="config-input" value="Admin" placeholder="Nome"/>
                    </div>
                    <div class="config-row">
                        <div class="config-info">
                            <span class="config-label">E-mail</span>
                            <span class="config-desc">Usado para alertas e notificações</span>
                        </div>
                        <input type="email" class="config-input" placeholder="email@exemplo.com"/>
                    </div>
                    <div class="config-row">
                        <div class="config-info">
                            <span class="config-label">Nova senha</span>
                            <span class="config-desc">Deixe em branco para manter a atual</span>
                        </div>
                        <input type="password" class="config-input" placeholder="••••••••"/>
                    </div>
                    <div class="card-footer">
                        <button class="btn-salvar">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Salvar Alterações
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
function mudarAba(aba, btn) {
    document.querySelectorAll('.aba-content').forEach(a => a.style.display = 'none');
    document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
    document.getElementById('aba-' + aba).style.display = 'block';
    btn.classList.add('active');
}
</script>
</body>
</html>
