<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AirGuard - Configurações</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/configuracao.css">
</head>
<body>
<div class="layout">

    <!-- ── Sidebar ── -->
    <nav class="sidebar">
        <div class="sidebar-logo">
           <img src="/img/logo.png" alt="Logo" style="width: 32px; height: 32px; object-fit: contain;">
            <span class="sidebar-logo-text">AirGuard</span>
        </div>
        <a href="/home"          class="nav-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><path d="M9 21V12h6v9"/></svg>Dashboard</a>
        <a href="/historico"     class="nav-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>Histórico</a>
        <a href="/sensores"      class="nav-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>Sensores</a>
        <a href="/configuracoes" class="nav-item active"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>Configurações</a>
        <div class="sidebar-footer">
            <div class="footer-status"><span class="dot-green"></span><span>Sistema Online</span></div>
            <div class="footer-quality">Qualidade do Ar: <strong>Boa</strong><span class="check-circle"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span></div>
        </div>
    </nav>

    <div class="main">
        <header class="top-header">
            <div class="header-left"><h1>Configurações</h1></div>
            <div class="header-right">
                <div class="notif-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 01-3.46 0"/>
                    </svg>
                </div>
                <div class="user-wrapper">
                    <div class="user-info" id="user-btn" onclick="toggleUserMenu()">
                        <div class="user-avatar">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <span><%= typeof usuario !== 'undefined' ? usuario : 'Usuário' %></span>
                        <span class="user-badge"><%= typeof perfil !== 'undefined' ? perfil.toUpperCase() : 'USR' %></span>
                        <svg class="seta" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>
                    <div class="user-dropdown" id="user-dd">
                        <div class="dd-head">
                            <div class="dd-av"><%= (typeof usuario !== 'undefined' ? usuario : 'U').substring(0,2).toUpperCase() %></div>
                            <div>
                                <div class="dd-name"><%= typeof usuario !== 'undefined' ? usuario : 'Usuário' %></div>
                                <div class="dd-role"><%= typeof perfil !== 'undefined' ? perfil.toUpperCase() : 'USUÁRIO' %></div>
                            </div>
                        </div>
                        <div class="dd-body">
                            <a href="#" class="dd-item" onclick="fecharMenu(); setTimeout(() => window.location.href='/configuracoes#perfil', 100)">
                                <span class="dd-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                                Meu perfil
                            </a>
                            <div class="dd-sep"></div>
                            <a class="dd-item danger" onclick="logout()">
                                <span class="dd-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span>
                                Sair
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content">

            <!-- Abas -->
            <div class="tabs-bar">
                <button class="tab active" onclick="mudarAba('sistema', this)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                    Sistema
                </button>
                <button class="tab" onclick="mudarAba('perfil', this)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Meu Perfil
                </button>
                <!-- aba usuários só para admin e superior -->
                <% if (typeof pode === 'function' && pode('usuario:editar')) { %>
                <button class="tab" onclick="mudarAba('usuarios', this)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                    Usuários
                </button>
                <button class="tab" onclick="mudarAba('logs', this)">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                    Logs
                </button>
                <% } %>
            </div>

            <!-- ══ ABA SISTEMA ══ -->
            <div id="aba-sistema" class="aba-content">
                <div class="cards-grid">

                    <div class="config-card">
                        <h3 class="card-title">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                            Configurações do Sistema
                        </h3>
                        <div class="config-row">
                            <div class="config-info"><span class="config-label">Intervalo global de leitura</span><span class="config-desc">Tempo entre leituras dos sensores (padrão)</span></div>
                            <select class="config-select"><option>5 segundos</option><option>10 segundos</option><option>30 segundos</option><option>1 minuto</option></select>
                        </div>
                        <div class="config-row">
                            <div class="config-info"><span class="config-label">Fuso horário</span><span class="config-desc">Selecione o fuso horário do sistema</span></div>
                            <select class="config-select"><option>America/Sao_Paulo</option><option>America/Manaus</option><option>America/Belem</option></select>
                        </div>
                        <div class="config-row">
                            <div class="config-info"><span class="config-label">Unidade de temperatura</span><span class="config-desc">Unidade padrão para exibição de temperatura</span></div>
                            <select class="config-select"><option>°C</option><option>°F</option></select>
                        </div>
                        <div class="config-row">
                            <div class="config-info"><span class="config-label">Unidade de concentração</span><span class="config-desc">Unidade padrão para gases</span></div>
                            <select class="config-select"><option>ppm</option><option>ppb</option><option>mg/m³</option></select>
                        </div>
                        <div class="card-footer"><button class="btn-salvar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>Salvar Alterações</button></div>
                    </div>

                    <div class="config-card">
                        <h3 class="card-title">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
                            Notificações e Alertas
                        </h3>
                        <div class="toggle-row"><div class="config-info"><span class="config-label">Alertas por e-mail</span><span class="config-desc">Receber alertas por e-mail</span></div><label class="toggle"><input type="checkbox" checked onchange="this.closest('.toggle').classList.toggle('on', this.checked)"><span class="toggle-slider"></span></label></div>
                        <div class="toggle-row"><div class="config-info"><span class="config-label">Alertas no sistema</span><span class="config-desc">Exibir alertas no painel</span></div><label class="toggle"><input type="checkbox" checked onchange="this.closest('.toggle').classList.toggle('on', this.checked)"><span class="toggle-slider"></span></label></div>
                        <div class="toggle-row"><div class="config-info"><span class="config-label">Níveis críticos</span><span class="config-desc">Notificar quando valores atingirem níveis críticos</span></div><label class="toggle"><input type="checkbox" checked onchange="this.closest('.toggle').classList.toggle('on', this.checked)"><span class="toggle-slider"></span></label></div>
                        <div class="toggle-row"><div class="config-info"><span class="config-label">Resumo diário</span><span class="config-desc">Receber resumo diário por e-mail</span></div><label class="toggle"><input type="checkbox" onchange="this.closest('.toggle').classList.toggle('on', this.checked)"><span class="toggle-slider"></span></label></div>
                        <div class="card-footer"><button class="btn-salvar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>Salvar Alterações</button></div>
                    </div>

                    <div class="config-card">
                        <h3 class="card-title">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                            Backup e Manutenção
                        </h3>
                        <div class="toggle-row"><div class="config-info"><span class="config-label">Backup automático</span><span class="config-desc">Realizar backup automático do banco de dados</span></div><label class="toggle on"><input type="checkbox" checked onchange="this.closest('.toggle').classList.toggle('on', this.checked)"><span class="toggle-slider"></span></label></div>
                        <div class="config-row"><div class="config-info"><span class="config-label">Frequência do backup</span><span class="config-desc">Defina a frequência dos backups automáticos</span></div><select class="config-select"><option>Diário</option><option>Semanal</option><option>Mensal</option></select></div>
                        <div class="config-row"><div class="config-info"><span class="config-label">Limpeza de dados antigos</span><span class="config-desc">Remover dados antigos automaticamente</span></div><select class="config-select"><option>90 dias</option><option>180 dias</option><option>1 ano</option><option>Nunca</option></select></div>
                        <div class="card-footer"><button class="btn-salvar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>Salvar Alterações</button></div>
                    </div>

                </div>
            </div>

            <!-- ══ ABA MEU PERFIL ══ -->
            <div id="aba-perfil" class="aba-content" style="display:none">
                <div class="perfil-card">
                    <div class="perfil-header">
                        <h3 class="card-title">Informações do Perfil</h3>
                        <p style="font-size:13px; color:#64748b; font-weight:600; margin-top:4px;">Gerencie suas informações pessoais e preferências da conta.</p>
                    </div>
                    <div class="perfil-body">
                        <div class="perfil-avatar-col">
                            <div class="perfil-avatar" id="perfil-avatar-circle">
                                <span id="perfil-initials"><%= (typeof usuario !== 'undefined' ? usuario : 'U').substring(0,2).toUpperCase() %></span>
                            </div>
                            <button class="btn-alterar-foto" onclick="document.getElementById('foto-input').click()">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                                Alterar foto
                            </button>
                            <input type="file" id="foto-input" accept="image/*" style="display:none" onchange="previewFoto(this)"/>
                            <p style="font-size:11px; color:#94a3b8; font-weight:600; margin-top:6px;">PNG ou JPG. Máx. 2MB.</p>
                        </div>
                        <div class="perfil-campos">
                            <div class="perfil-campo">
                                <label class="perfil-label">Nome completo</label>
                                <input type="text" class="perfil-input" id="perfil-nome" value="<%= typeof usuario !== 'undefined' ? usuario : '' %>" placeholder="Seu nome completo"/>
                            </div>
                            <div class="perfil-campo">
                                <label class="perfil-label">E-mail</label>
                                <input type="email" class="perfil-input" id="perfil-email" value="<%= typeof usuarioEmail !== 'undefined' ? usuarioEmail : '' %>" placeholder="seu@email.com"/>
                            </div>
                            <div style="margin-top:8px; padding-top:14px; border-top:1px solid #f1f5f9;">
                                <p style="font-size:12px; font-weight:800; color:#64748b; text-transform:uppercase; letter-spacing:.05em; margin:0 0 10px;">Alterar senha</p>
                            </div>
                            <div class="perfil-campo">
                                <label class="perfil-label">Senha atual</label>
                                <div class="perfil-input-wrap">
                                    <input type="password" class="perfil-input" id="senha-atual" placeholder="••••••••"/>
                                    <button class="toggle-senha" onclick="toggleSenha('senha-atual')"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                                </div>
                            </div>
                            <div class="perfil-campo">
                                <label class="perfil-label">Nova senha <span style="color:#94a3b8; font-weight:600;">(deixe em branco para não alterar)</span></label>
                                <div class="perfil-input-wrap">
                                    <input type="password" class="perfil-input" id="nova-senha" placeholder="Mínimo 8 caracteres"/>
                                    <button class="toggle-senha" onclick="toggleSenha('nova-senha')"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                                </div>
                            </div>
                            <div class="perfil-campo">
                                <label class="perfil-label">Confirmar nova senha</label>
                                <div class="perfil-input-wrap">
                                    <input type="password" class="perfil-input" id="conf-senha" placeholder="Repita a nova senha"/>
                                    <button class="toggle-senha" onclick="toggleSenha('conf-senha')"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                                </div>
                            </div>
                            <div id="perfil-erro" style="display:none; font-size:13px; color:#dc2626; background:#fff5f5; border:1px solid #fecaca; border-radius:8px; padding:8px 12px; margin-top:4px;"></div>
                        </div>
                    </div>
                    <div class="perfil-footer">
                        <button class="btn-cancelar-perfil" onclick="resetarPerfil()">Cancelar</button>
                        <button class="btn-salvar" onclick="salvarPerfil()">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Salvar alterações
                        </button>
                    </div>
                </div>
            </div>

            <!-- ══ ABA USUÁRIOS ══ -->
            <% if (typeof pode === 'function' && pode('usuario:editar')) { %>
            <div id="aba-usuarios" class="aba-content" style="display:none">
                <div class="config-card" style="max-width:100%">
                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                        <h3 class="card-title" style="margin:0">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                            Gerenciar Usuários
                        </h3>
                        <div style="display:flex; gap:14px; font-size:12px; font-weight:700; color:#64748b;">
                            <span style="display:flex; align-items:center; gap:5px;"><span style="width:8px;height:8px;border-radius:50%;background:#22c55e;display:inline-block"></span>Ativo — pode fazer login</span>
                            <span style="display:flex; align-items:center; gap:5px;"><span style="width:8px;height:8px;border-radius:50%;background:#ef4444;display:inline-block"></span>Inativo — acesso bloqueado</span>
                        </div>
                    </div>

                    <table class="usuarios-table">
                        <thead>
                            <tr>
                                <th>Usuário</th>
                                <th>E-mail</th>
                                <th>Perfil</th>
                                <th>Status</th>
                                <th>Cadastrado em</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% (usuarios || []).forEach(u => { %>
                            <tr id="usuario-row-<%= u.id %>">
                                <td><strong><%= u.nome %></strong></td>
                                <td style="color:#64748b"><%= u.email %></td>
                                <td>
                                    <% if (typeof pode === 'function' && pode('usuario:alterarPerfil') && u.perfil !== 'superadmin') { %>
                                    <select class="select-perfil" onchange="alterarPerfil(<%= u.id %>, this.value)">
                                        <option value="funcionario" <%= u.perfil==='funcionario'?'selected':'' %>>Funcionário</option>
                                        <option value="admin"       <%= u.perfil==='admin'      ?'selected':'' %>>Admin</option>
                                        <option value="superadmin"  <%= u.perfil==='superadmin' ?'selected':'' %>>SuperAdmin</option>
                                    </select>
                                    <% } else { %>
                                    <span class="perfil-badge <%= u.perfil %>"><%= u.perfil %></span>
                                    <% } %>
                                </td>
                                <td>
                                    <span style="display:flex; align-items:center; gap:6px; font-size:13px; font-weight:700; color:<%= u.status ? '#16a34a' : '#ef4444' %>">
                                        <span style="width:8px;height:8px;border-radius:50%;background:<%= u.status ? '#22c55e' : '#ef4444' %>;display:inline-block;flex-shrink:0"></span>
                                        <%= u.status ? 'Ativo' : 'Inativo' %>
                                    </span>
                                </td>
                                <td style="color:#94a3b8; font-size:12px;"><%= new Date(u.created_at).toLocaleDateString('pt-BR') %></td>
                                <td>
                                    <div style="display:flex; gap:6px; flex-wrap:wrap;">
                                        <button class="btn-usuario-acao" onclick="toggleStatusUsuario(<%= u.id %>, <%= u.status %>)" title="<%= u.status ? 'Bloquear acesso' : 'Reativar acesso' %>">
                                            <%= u.status ? 'Desativar' : 'Ativar' %>
                                        </button>
                                        <% if (typeof pode === 'function' && pode('usuario:excluir') && u.perfil !== 'superadmin') { %>
                                        <button class="btn-usuario-acao danger" onclick="excluirUsuario(<%= u.id %>, '<%= u.nome.replace(/'/g, "\\'") %>')">Excluir</button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                            <% if (!usuarios || usuarios.length === 0) { %>
                            <tr><td colspan="6" style="text-align:center; color:#94a3b8; padding:24px; font-weight:600;">Nenhum usuário encontrado.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ══ ABA LOGS ══ -->
            <div id="aba-logs" class="aba-content" style="display:none">
                <div class="config-card" style="max-width:100%">
                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; flex-wrap:wrap; gap:10px;">
                        <h3 class="card-title" style="margin:0">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                            Logs do Sistema
                        </h3>
                        <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                            <select id="filtro-log-tipo" class="config-select" style="font-size:12px; padding:5px 10px;" onchange="carregarLogs()">
                                <option value="">Todos os eventos</option>
                                <option value="INSERT">Inserções</option>
                                <option value="UPDATE">Atualizações</option>
                                <option value="DELETE">Exclusões</option>
                                <option value="LOGIN">Logins</option>
                                <option value="LOGOUT">Logouts</option>
                            </select>
                            <select id="filtro-log-tabela" class="config-select" style="font-size:12px; padding:5px 10px;" onchange="carregarLogs()">
                                <option value="">Todas as tabelas</option>
                                <option value="usuarios">Usuários</option>
                                <option value="estacoes">Estações</option>
                                <option value="sensores">Sensores</option>
                            </select>
                            <button class="btn-salvar" style="padding:6px 14px; font-size:12px;" onclick="carregarLogs()">↺ Atualizar</button>
                        </div>
                    </div>

                    <div style="background:#f0f9ff; border:1px solid #bae6fd; border-radius:10px; padding:10px 14px; margin-bottom:14px; font-size:12px; color:#0369a1; font-weight:600; display:flex; gap:8px; align-items:flex-start;">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        Os logs registram automaticamente todas as ações importantes — criação, edição e exclusão de estações, sensores e usuários. São gerados pelos triggers do banco e não podem ser apagados manualmente.
                    </div>

                    <div id="logs-lista">
                        <div style="text-align:center; color:#94a3b8; padding:24px; font-weight:600;">Clique em "Atualizar" para carregar os logs.</div>
                    </div>
                </div>
            </div>
            <% } %>

        </div>
    </div>
</div>

<script src="/js/permissao.js"></script>
<script>

// ── Dados do EJS ──────────────────────────────────────────
const NOME_ORIGINAL  = '<%= (typeof usuario !== "undefined" ? usuario : "").replace(/\'/g, "\\'") %>';
const EMAIL_ORIGINAL = '<%= (typeof usuarioEmail !== "undefined" ? usuarioEmail : "").replace(/\'/g, "\\'") %>';

// ── Menus ─────────────────────────────────────────────────
function toggleUserMenu() {
    document.getElementById('user-btn').classList.toggle('open');
    document.getElementById('user-dd').classList.toggle('open');
}
document.addEventListener('click', e => {
    const w = document.querySelector('.user-wrapper');
    if (w && !w.contains(e.target)) {
        document.getElementById('user-btn')?.classList.remove('open');
        document.getElementById('user-dd')?.classList.remove('open');
    }
});
function fecharMenu() {
    document.getElementById('user-btn')?.classList.remove('open');
    document.getElementById('user-dd')?.classList.remove('open');
}
async function logout() {
    await fetch('/logout', { method: 'POST' });
    window.location.href = '/login';
}

// ── Abas principais ───────────────────────────────────────
function mudarAba(aba, btn) {
    document.querySelectorAll('.aba-content').forEach(a => a.style.display = 'none');
    document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
    const el = document.getElementById('aba-' + aba);
    if (el) el.style.display = 'block';
    if (btn) btn.classList.add('active');

    // carrega logs automaticamente ao entrar na aba
    if (aba === 'logs') carregarLogs();
}

function ativarPorAncora() {
    const ancora = window.location.hash.replace('#', '');
    if (ancora) {
        const btn = document.querySelector(`.tab[onclick*="'${ancora}'"]`);
        if (btn) mudarAba(ancora, btn);
    }
}

window.addEventListener('load', ativarPorAncora);
window.addEventListener('hashchange', ativarPorAncora);

// ── Utilitários ───────────────────────────────────────────
function toggleSenha(id) {
    const input = document.getElementById(id);
    input.type = input.type === 'password' ? 'text' : 'password';
}

function previewFoto(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            const circle = document.getElementById('perfil-avatar-circle');
            circle.style.backgroundImage    = `url(${e.target.result})`;
            circle.style.backgroundSize     = 'cover';
            circle.style.backgroundPosition = 'center';
            document.getElementById('perfil-initials').style.display = 'none';
        };
        reader.readAsDataURL(input.files[0]);
    }
}

// ── Toast ─────────────────────────────────────────────────
function toast(msg, tipo = 'sucesso') {
    let el = document.getElementById('_toast_cfg');
    if (!el) {
        el = document.createElement('div');
        el.id = '_toast_cfg';
        el.style.cssText = `position:fixed;bottom:24px;right:24px;z-index:9999;padding:12px 20px;border-radius:10px;font-family:Nunito,sans-serif;font-size:13px;font-weight:700;box-shadow:0 4px 20px rgba(0,0,0,.15);opacity:0;transform:translateY(12px);transition:all .2s ease;pointer-events:none;max-width:320px;`;
        document.body.appendChild(el);
    }
    el.textContent = msg;
    el.style.background = tipo === 'sucesso' ? '#dcfce7' : '#fee2e2';
    el.style.color      = tipo === 'sucesso' ? '#15803d'  : '#b91c1c';
    el.style.border     = tipo === 'sucesso' ? '1px solid #bbf7d0' : '1px solid #fecaca';
    el.style.opacity    = '1';
    el.style.transform  = 'translateY(0)';
    setTimeout(() => { el.style.opacity = '0'; el.style.transform = 'translateY(12px)'; }, 3500);
}

// ── Perfil ────────────────────────────────────────────────
function resetarPerfil() {
    document.getElementById('perfil-nome').value  = NOME_ORIGINAL;
    document.getElementById('perfil-email').value = EMAIL_ORIGINAL;
    document.getElementById('senha-atual').value  = '';
    document.getElementById('nova-senha').value   = '';
    document.getElementById('conf-senha').value   = '';
    document.getElementById('perfil-erro').style.display = 'none';
}

async function salvarPerfil() {
    const nome  = document.getElementById('perfil-nome').value.trim();
    const email = document.getElementById('perfil-email').value.trim();
    const senhaAtual = document.getElementById('senha-atual').value;
    const novaSenha  = document.getElementById('nova-senha').value;
    const confSenha  = document.getElementById('conf-senha').value;
    const erroEl = document.getElementById('perfil-erro');
    erroEl.style.display = 'none';

    if (!nome || !email) {
        erroEl.textContent   = 'Nome e e-mail são obrigatórios.';
        erroEl.style.display = 'block';
        return;
    }

    if (novaSenha) {
        if (novaSenha !== confSenha) {
            erroEl.textContent   = 'As senhas não coincidem.';
            erroEl.style.display = 'block';
            return;
        }
        if (novaSenha.length < 8) {
            erroEl.textContent   = 'A nova senha deve ter pelo menos 8 caracteres.';
            erroEl.style.display = 'block';
            return;
        }
    }

    try {
        const r = await fetch('/api/me/perfil', {
            method:  'PUT',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ nome, email })
        });
        const j = await r.json();
        if (!r.ok) { erroEl.textContent = j.erro; erroEl.style.display = 'block'; return; }
    } catch {
        erroEl.textContent   = 'Erro de conexão.';
        erroEl.style.display = 'block';
        return;
    }

    if (novaSenha) {
        try {
            const r = await fetch('/api/me/senha', {
                method:  'PUT',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ senha_atual: senhaAtual, nova_senha: novaSenha, confirmar_senha: confSenha })
            });
            const j = await r.json();
            if (!r.ok) { erroEl.textContent = j.erro; erroEl.style.display = 'block'; return; }
        } catch {
            erroEl.textContent   = 'Erro de conexão.';
            erroEl.style.display = 'block';
            return;
        }
        document.getElementById('senha-atual').value = '';
        document.getElementById('nova-senha').value  = '';
        document.getElementById('conf-senha').value  = '';
    }

    toast('Perfil atualizado com sucesso!');
}

// ── Usuários ──────────────────────────────────────────────
async function alterarPerfil(id, novoPerfil) {
    try {
        const r = await fetch(`/api/usuarios/${id}/perfil`, {
            method:  'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ perfil: novoPerfil })
        });
        const j = await r.json();
        if (r.ok) toast('Perfil atualizado!');
        else { toast(j.erro || 'Erro ao atualizar perfil.', 'erro'); location.reload(); }
    } catch { toast('Erro de conexão.', 'erro'); }
}

async function toggleStatusUsuario(id, statusAtual) {
    const novoStatus = statusAtual ? 0 : 1;
    const acao = novoStatus ? 'Ativar' : 'Desativar';
    const texto = novoStatus
        ? 'O usuário poderá fazer login normalmente.'
        : 'O usuário terá o acesso bloqueado. Os dados dele serão preservados.';

    confirmarAcao({
        titulo:   `${acao} usuário?`,
        texto,
        tipo:     novoStatus ? 'success' : 'warning',
        btnLabel: acao,
        onConfirm: async () => {
            const r = await fetch(`/api/usuarios/${id}/status`, {
                method:  'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ status: novoStatus })
            });
            const j = await r.json();
            if (r.ok) { toast(novoStatus ? 'Usuário ativado!' : 'Usuário desativado!'); setTimeout(() => location.reload(), 800); }
            else throw new Error(j.erro || 'Erro.');
        }
    });
}

async function excluirUsuario(id, nome) {
    confirmarSuperAdmin({
        titulo:   `Excluir ${nome}?`,
        texto:    'O usuário e todos os seus dados serão removidos permanentemente.',
        tipo:     'danger',
        btnLabel: 'Excluir',
        onConfirm: async (senha) => {
            const r = await fetch(`/api/usuarios/${id}`, {
                method:  'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ senha_superadmin: senha })
            });
            const j = await r.json();
            if (!r.ok) throw new Error(j.erro || 'Erro ao excluir.');
            document.getElementById(`usuario-row-${id}`)?.remove();
            toast('Usuário excluído!');
        }
    });
}

// ── Logs ──────────────────────────────────────────────────
const ICONE_EVENTO = { INSERT:'🟢', UPDATE:'🟡', DELETE:'🔴', LOGIN:'🔵', LOGOUT:'⚪' };
const COR_EVENTO   = { INSERT:'#dcfce7', UPDATE:'#fef9c3', DELETE:'#fee2e2', LOGIN:'#dbeafe', LOGOUT:'#f1f5f9' };

async function carregarLogs() {
    const tipo   = document.getElementById('filtro-log-tipo')?.value   || '';
    const tabela = document.getElementById('filtro-log-tabela')?.value || '';
    const lista  = document.getElementById('logs-lista');
    if (!lista) return;

    lista.innerHTML = '<div style="text-align:center; color:#94a3b8; padding:24px; font-weight:600;">Carregando...</div>';

    try {
        const params = new URLSearchParams();
        if (tipo)   params.set('tipo', tipo);
        if (tabela) params.set('tabela', tabela);

        const res  = await fetch(`/api/logs?${params.toString()}`);
        const json = await res.json();
        const logs = json.logs ?? json;

        if (!logs || logs.length === 0) {
            lista.innerHTML = '<div style="text-align:center; color:#94a3b8; padding:24px; font-weight:600;">Nenhum log encontrado.</div>';
            return;
        }

        lista.innerHTML = `
            <table style="width:100%; border-collapse:collapse; font-size:13px;">
                <thead>
                    <tr style="border-bottom:1px solid #e2e8f0;">
                        <th style="text-align:left; padding:8px 12px; font-size:11px; font-weight:800; color:#64748b; text-transform:uppercase; white-space:nowrap;">Evento</th>
                        <th style="text-align:left; padding:8px 12px; font-size:11px; font-weight:800; color:#64748b; text-transform:uppercase;">Tabela</th>
                        <th style="text-align:left; padding:8px 12px; font-size:11px; font-weight:800; color:#64748b; text-transform:uppercase;">Descrição</th>
                        <th style="text-align:left; padding:8px 12px; font-size:11px; font-weight:800; color:#64748b; text-transform:uppercase; white-space:nowrap;">Data / Hora</th>
                    </tr>
                </thead>
                <tbody>
                    ${logs.map(l => `
                        <tr style="border-bottom:1px solid #f8fafc;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
                            <td style="padding:10px 12px;">
                                <span style="display:inline-flex; align-items:center; gap:6px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:800; background:${COR_EVENTO[l.tipo_evento]||'#f1f5f9'}">
                                    ${ICONE_EVENTO[l.tipo_evento]||'⚪'} ${l.tipo_evento}
                                </span>
                            </td>
                            <td style="padding:10px 12px; color:#64748b; font-weight:600;">${l.tabela_afetada || '--'}</td>
                            <td style="padding:10px 12px; color:#1e3a5f; font-weight:600;">${l.descricao || '--'}</td>
                            <td style="padding:10px 12px; color:#94a3b8; font-size:12px; white-space:nowrap;">${new Date(l.created_at).toLocaleString('pt-BR', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'})}</td>
                        </tr>
                    `).join('')}
                </tbody>
            </table>
        `;
    } catch (e) {
        console.error(e);
        lista.innerHTML = '<div style="text-align:center; color:#ef4444; padding:24px; font-weight:600;">Erro ao carregar logs.</div>';
    }
}

</script>

<style>
/* ── Tabela de usuários ── */
.usuarios-table { width: 100%; border-collapse: collapse; }
.usuarios-table th {
    text-align: left; font-size: 11px; font-weight: 800;
    color: #64748b; text-transform: uppercase; letter-spacing: .05em;
    padding: 8px 12px; border-bottom: 1px solid #e2e8f0;
}
.usuarios-table td {
    padding: 11px 12px; font-size: 13px; font-weight: 600;
    color: #1e3a5f; border-bottom: 1px solid #f1f5f9; vertical-align: middle;
}
.usuarios-table tr:last-child td { border-bottom: none; }

.perfil-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 10px; border-radius: 99px; font-size: 11px; font-weight: 800;
}
.perfil-badge.superadmin { background: #fef9c3; color: #854d0e; }
.perfil-badge.admin      { background: #dbeafe; color: #1d4ed8; }
.perfil-badge.funcionario{ background: #f1f5f9; color: #475569; }

.select-perfil {
    border: 1px solid #e2e8f0; border-radius: 7px; padding: 4px 8px;
    font-family: Nunito, sans-serif; font-size: 12px; font-weight: 700;
    color: #1e3a5f; background: #fff; cursor: pointer; outline: none;
}

.btn-usuario-acao {
    background: none; border: 1px solid #e2e8f0; border-radius: 7px;
    padding: 4px 10px; font-family: Nunito, sans-serif; font-size: 12px;
    font-weight: 700; cursor: pointer; color: #64748b; transition: all .12s;
}
.btn-usuario-acao:hover { background: #f1f5f9; }
.btn-usuario-acao.danger { color: #ef4444; border-color: #fee2e2; }
.btn-usuario-acao.danger:hover { background: #fff5f5; }
</style>

</body>
</html>
