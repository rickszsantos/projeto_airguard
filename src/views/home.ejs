</div>

<!--
═══════════════════════════════════════════════════════
SCRIPTS — CHART.JS + WEBSOCKET
Adicione a tag <script src="chart.js CDN"> no <head>
e cole o bloco abaixo antes do </body>
═══════════════════════════════════════════════════════
-->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // ── Inicialização do gráfico ─────────────────────────
    const ctx       = document.getElementById('meuGrafico').getContext('2d');
    const maxPontos = 20;

    const grafico = new Chart(ctx, {
        type: 'line',
        data: {
            labels: [],
            datasets: [
                {
                    label: 'Temperatura (°C)',
                    data: [],
                    borderColor: '#e74c3c',
                    backgroundColor: 'rgba(231,76,60,0.08)',
                    borderWidth: 2.5,
                    pointRadius: 4,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#e74c3c',
                    pointBorderWidth: 2,
                    tension: 0.4,
                    fill: true
                },
                {
                    label: 'Umidade (%)',
                    data: [],
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37,99,235,0.08)',
                    borderWidth: 2.5,
                    pointRadius: 4,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#2563eb',
                    pointBorderWidth: 2,
                    tension: 0.4,
                    fill: true
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            plugins: {
                legend: {
                    position: 'top',
                    labels: {
                        font: { family: 'Nunito', size: 13, weight: '700' },
                        color: '#1e3a5f',
                        usePointStyle: true,
                        pointStyleWidth: 10
                    }
                }
            },
            scales: {
                x: {
                    ticks: {
                        font: { family: 'Nunito', size: 11 },
                        color: '#64748b',
                        maxTicksLimit: 10
                    },
                    grid: { color: 'rgba(37,99,235,0.07)' }
                },
                y: {
                    beginAtZero: false,
                    ticks: {
                        font: { family: 'Nunito', size: 11 },
                        color: '#64748b'
                    },
                    grid: { color: 'rgba(37,99,235,0.07)' }
                }
            }
        }
    });

    // ── Adiciona leitura no gráfico e nos cards ──────────
    function adicionarLeitura(dado) {
        const agora = new Date().toLocaleTimeString('pt-br', {
            hour: '2-digit', minute: '2-digit', second: '2-digit'
        });

        grafico.data.labels.push(agora);
        grafico.data.datasets[0].data.push(dado.temperatura);
        grafico.data.datasets[1].data.push(dado.umidade);

        // remove pontos antigos
        if (grafico.data.labels.length > maxPontos) {
            grafico.data.labels.shift();
            grafico.data.datasets[0].data.shift();
            grafico.data.datasets[1].data.shift();
        }

        grafico.update();

        // atualiza os cards
        if (dado.temperatura !== undefined)
            document.getElementById('temperatura').textContent = dado.temperatura;
        if (dado.umidade !== undefined)
            document.getElementById('umidade').textContent = dado.umidade;
    }

    // ── Conexão WebSocket — atualização em tempo real ────
    function conectarWS() {
        const ws = new WebSocket('ws://' + location.host);

        ws.onopen = () => console.log('Dashboard conectado ao servidor!');

        ws.onmessage = (event) => {
            const dado = JSON.parse(event.data);
            adicionarLeitura(dado);
        };

        ws.onclose = () => {
            console.log('WebSocket desconectado — reconectando em 3s...');
            setTimeout(conectarWS, 3000); // reconecta sem recarregar a página
        };

        ws.onerror = (err) => console.error('Erro WebSocket:', err);
    }

    conectarWS();
</script>

</body>
</html>