<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AirGuard - Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/home.css">
</head>






<body>
<div class="layout">

    <!-- ── Sidebar ── -->
    <nav class="sidebar">
        <div class="sidebar-logo">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                <rect width="36" height="36" rx="10" fill="rgba(255,255,255,0.18)"/>
                <path d="M18 8 L26 12 L26 20 C26 24.4 22.4 28 18 29 C13.6 28 10 24.4 10 20 L10 12 Z" fill="white" opacity="0.9"/>
                <ellipse cx="18" cy="16" rx="6" ry="4" fill="#2563eb" opacity="0.7"/>
                <path d="M12 20 Q18 24 24 20" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            </svg>
            <span class="sidebar-logo-text">AirGuard</span>
        </div>

        <a href="/home" class="nav-item active">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
                <path d="M9 21V12h6v9"/>
            </svg>
            Dashboard
        </a>
        <a href="/historico" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>
            </svg>
            Histórico
        </a>
        <a href="/sensores" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
            Sensores
        </a>
        <a href="/configuracoes" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
            </svg>
            Configurações
        </a>

        <!-- Footer da sidebar igual ao sensor.ejs -->
        <div class="sidebar-footer">
            <div class="footer-status">
                <span class="dot-green"></span>
                <span>Sistema Online</span>
            </div>
            <div class="footer-quality">
                Qualidade do Ar: <strong id="sidebar-qualidade">Boa</strong>
                <span class="check-circle">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </span>
            </div>
        </div>
    </nav>

    <!-- ── Main ── -->
    <div class="main">

        <header class="top-header">
            <div class="header-left">
                <h1>Dashboard</h1>
            </div>
            <div class="header-right">
                <div class="notif-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 01-3.46 0"/>
                    </svg>
                </div>
                <div class="user-wrapper">  
                <div class="user-info" id="user-btn" onclick="toggleUserMenu()">
                    <div class="user-avatar">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    
                    </div>
                    <!-- dados do usuário via EJS -->
                    <span><%= typeof usuario !== 'undefined' ? usuario : 'Usuário' %></span>
                    <span class="user-badge"><%= typeof perfil !== 'undefined' ? perfil.toUpperCase() : 'USR' %></span>
                    

                    <!-- seta para mostrar o menu -->
                    <svg class="seta" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                    
                </div>           
  <div class="user-dropdown" id="user-dd">
    <div class="dd-head">
      <div class="dd-av">
        <%= (typeof usuario !== 'undefined' ? usuario : 'U').substring(0,2).toUpperCase() %>
      </div>
      <div>
        <div class="dd-name"><%= typeof usuario !== 'undefined' ? usuario : 'Usuário' %></div>
        <div class="dd-role"><%= typeof perfil !== 'undefined' ? perfil.toUpperCase() : 'USUÁRIO' %></div>
      </div>
    </div>
    <div class="dd-body">
      <a href="/configuracoes#perfil" class="dd-item" >
        <span class="dd-icon" >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        </span>
        Meu perfil
      </a>
      <a href="/configuracoes" class="dd-item">
        <span class="dd-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
          </svg>
        </span>
        Configurações
      </a>
      <div class="dd-sep"></div>
                        <a class="dd-item danger" onclick="logout()">
                            <span class="dd-icon">
                              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                                    <polyline points="16 17 21 12 16 7"/>
                                 <line x1="21" y1="12" x2="9" y2="12"/>
                              </svg>
                            </span>
                            Sair
                        </a>
                    </div>
                    </div>
                </div>
   
            </div>
        </header>

        <div class="content">

            <!-- Cards de leitura atual -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="label">Temperatura</div>
                    <div class="value-row">
                        <svg width="24" height="28" viewBox="0 0 28 32" fill="none">
                            <rect x="11" y="2" width="6" height="18" rx="3" fill="#bfdbfe"/>
                            <circle cx="14" cy="24" r="6" fill="#3b82f6"/>
                            <rect x="12" y="8" width="4" height="14" rx="2" fill="#3b82f6"/>
                        </svg>
                        <span class="value" id="card-temp">--</span>
                        <span class="unit">°C</span>
                    </div>
                    <div class="stat-sub">Atualizado agora</div>
                </div>
                <div class="stat-card">
                    <div class="label">Umidade</div>
                    <div class="value-row">
                        <svg width="22" height="28" viewBox="0 0 26 32" fill="none">
                            <path d="M13 3 C13 3 3 14 3 20 a10 10 0 0 0 20 0 C23 14 13 3 13 3Z" fill="#3b82f6"/>
                            <ellipse cx="9" cy="19" rx="2.5" ry="3.5" fill="rgba(255,255,255,0.3)" transform="rotate(-20 9 19)"/>
                        </svg>
                        <span class="value" id="card-umidade">--</span>
                        <span class="unit">%</span>
                    </div>
                    <div class="stat-sub">Atualizado agora</div>
                </div>
                <div class="stat-card">
                    <div class="label">Gases (MQ135)</div>
                    <div class="value-row">
                        <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
                            <ellipse cx="16" cy="18" rx="11" ry="7" fill="#dbeafe"/>
                            <ellipse cx="11" cy="17" rx="6" ry="5" fill="#bfdbfe"/>
                            <ellipse cx="20" cy="15" rx="5" ry="5" fill="#93c5fd"/>
                            <ellipse cx="16" cy="14" rx="6" ry="5" fill="#60a5fa"/>
                            <text x="16" y="22" text-anchor="middle" font-size="6" font-weight="700" fill="#1a56c4" font-family="Nunito,sans-serif">GAS</text>
                        </svg>
                        <span class="value" id="card-gases">--</span>
                        <span class="unit">ppm</span>
                    </div>
                    <div class="stat-sub">Atualizado agora</div>
                </div>
                <div class="stat-card">
                    <div class="label">CO (MQ7)</div>
                    <div class="value-row">
                        <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
                            <circle cx="16" cy="16" r="13" fill="#f3e8ff"/>
                            <text x="16" y="21" text-anchor="middle" font-size="8" font-weight="800" fill="#7c3aed" font-family="Nunito,sans-serif">CO</text>
                        </svg>
                        <span class="value" id="card-co">--</span>
                        <span class="unit">ppm</span>
                    </div>
                    <div class="stat-sub">Atualizado agora</div>
                </div>
            </div>

            <!-- Gráfico + menu seletor -->
            <div class="chart-row">
                <div class="chart-card">
                    <h2 id="grafico-titulo">Temperatura em Tempo Real (°C)</h2>
                    <div class="chart-wrap">
                        <canvas id="meuGrafico"></canvas>
                    </div>
                </div>

                <!-- Menu lateral de seleção -->
                <div class="chart-menu">
                    <div class="chart-menu-title">Visualizar</div>
                    <button class="chart-btn active" onclick="selecionarGrafico('temperatura', this)">
                        <span class="btn-dot" style="background:#e74c3c"></span>Temperatura
                    </button>
                    <button class="chart-btn" onclick="selecionarGrafico('umidade', this)">
                        <span class="btn-dot" style="background:#2563eb"></span>Umidade
                    </button>
                    <button class="chart-btn" onclick="selecionarGrafico('gases', this)">
                        <span class="btn-dot" style="background:#f59e0b"></span>Gases (MQ135)
                    </button>
                    <button class="chart-btn" onclick="selecionarGrafico('CO', this)">
                        <span class="btn-dot" style="background:#8b5cf6"></span>CO (MQ7)
                    </button>
                    <div class="chart-menu-sep"></div>
                    <button class="chart-btn" onclick="selecionarGrafico('todos', this)">
                        <span class="btn-dot" style="background:linear-gradient(135deg,#e74c3c,#2563eb)"></span>Todos
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>



<script>
    window.__ULTIMAS__ = <%- JSON.stringify(typeof ultimas !== 'undefined' ? ultimas : []) %>;
</script>

<script>

//opção de logout 
async function logout() {
    await fetch('/logout', { method: 'POST' });
    window.location.href = '/login';
}




//ancora do menu para passar direto para o perfil
window.addEventListener('load', () => {
    const ancora = window.location.hash.replace('#', '');

    if (ancora) {
        const btn = document.querySelector(`[onclick*="'${ancora}'"]`);
        if (btn) mudarAba(ancora, btn);
    }
});

function toggleUserMenu() {
    document.getElementById('user-btn').classList.toggle('open');
    document.getElementById('user-dd').classList.toggle('open');
}
document.addEventListener('click', e => {
    const w = document.querySelector('.user-wrapper');
    if (w && !w.contains(e.target)) {
        document.getElementById('user-btn')?.classList.remove('open');
        document.getElementById('user-dd')?.classList.remove('open');
    }
});




const DATASETS = {
    temperatura: { label:'Temperatura (°C)',  titulo:'Temperatura em Tempo Real',  cor:'#e74c3c' },
    umidade:     { label:'Umidade (%)',        titulo:'Umidade em Tempo Real',       cor:'#2563eb' },
    gases:       { label:'Gases MQ135 (ppm)', titulo:'Gases MQ135 em Tempo Real',   cor:'#f59e0b' },
    CO:          { label:'CO MQ7 (ppm)',      titulo:'CO MQ7 em Tempo Real',        cor:'#8b5cf6' }
};

const MAX   = 20;   // janela deslizante — máximo de pontos
let modo    = 'temperatura';
let labels  = [];
const hist  = { temperatura:[], umidade:[], gases:[], CO:[] };

// ── Gráfico ───────────────────────────────────────────────
const ctx = document.getElementById('meuGrafico').getContext('2d');
const grafico = new Chart(ctx, {
    type: 'line',
    data: { labels: [], datasets: [] },
    options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { position:'top', onClick: () => {}, labels:{ font:{ family:'Nunito', size:12, weight:'700' }, color:'#1e3a5f', usePointStyle:true } } },
        scales: {
            x: { ticks:{ font:{ family:'Nunito',size:10 }, color:'#64748b', maxTicksLimit:8 }, grid:{ color:'rgba(37,99,235,0.06)' } },
            y: { beginAtZero:false, ticks:{ font:{ family:'Nunito',size:10 }, color:'#64748b' }, grid:{ color:'rgba(37,99,235,0.06)' } }
        }
    }
});

// ── Aplica modo no gráfico ────────────────────────────────
function aplicarModo(m) {
    if (m === 'todos') {
        grafico.data.labels   = [...labels];
        grafico.data.datasets = Object.entries(DATASETS).map(([k,d])=>({
            label:d.label, data:[...hist[k]], borderColor:d.cor,
            backgroundColor:d.cor+'18', borderWidth:2, pointRadius:3, tension:0.4, fill:false
        }));
        document.getElementById('grafico-titulo').textContent = 'Todos os Sensores';
    } else {
        const d = DATASETS[m];
        grafico.data.labels   = [...labels];
        grafico.data.datasets = [{
            label:d.label, data:[...hist[m]], borderColor:d.cor,
            backgroundColor:d.cor+'18', borderWidth:2.5, pointRadius:4,
            pointBackgroundColor:'#fff', pointBorderColor:d.cor, pointBorderWidth:2,
            tension:0.4, fill:true
        }];
        document.getElementById('grafico-titulo').textContent = d.titulo;
    }
    grafico.update();
}

function selecionarGrafico(m, btn) {
    modo = m;
    document.querySelectorAll('.chart-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    aplicarModo(modo);
}

// ── Adiciona ponto na janela deslizante ───────────────────
function adicionarLeitura(dado) {
    const agora = new Date().toLocaleTimeString('pt-br',{ hour:'2-digit', minute:'2-digit', second:'2-digit' });

    labels.push(agora);
    Object.keys(hist).forEach(k => hist[k].push(dado[k] ?? null));

    // janela deslizante — remove o mais antigo se passar de MAX
    if (labels.length > MAX) {
        labels.shift();
        Object.keys(hist).forEach(k => hist[k].shift());
    }

    aplicarModo(modo);

    // atualiza cards
    if (dado.temperatura !== undefined) document.getElementById('card-temp').textContent    = dado.temperatura;
    if (dado.umidade      !== undefined) document.getElementById('card-umidade').textContent = dado.umidade;
    if (dado.gases        !== undefined) document.getElementById('card-gases').textContent   = dado.gases;
    if (dado.CO           !== undefined) document.getElementById('card-co').textContent      = dado.CO;
}

// ── Atualiza badge de alertas ─────────────────────────────
function atualizarBadgeAlerta(total, lista) {
    const badge = document.getElementById('notif-badge');
    if (!badge) return;
    badge.textContent  = total;
    badge.style.display = total > 0 ? 'flex' : 'none';

    // atualiza o dropdown de alertas se estiver aberto
    const dropdown = document.getElementById('alertas-dropdown');
    if (dropdown && dropdown.style.display !== 'none') {
        renderizarAlertas(lista);
    }
}

// ── Renderiza lista de alertas no dropdown ────────────────
function renderizarAlertas(lista) {
    const el = document.getElementById('alertas-lista');
    if (!el) return;
    if (!lista || lista.length === 0) {
        el.innerHTML = '<div class="alerta-vazio">Nenhum alerta ativo</div>';
        return;
    }
    el.innerHTML = lista.map(a => `
        <div class="alerta-item ${a.tipo.includes('CRITICO') || a.tipo.includes('CRITICA') ? 'critico' : 'atencao'}">
            <div class="alerta-msg">${a.mensagem}</div>
            <div class="alerta-meta">${a.estacao} · ${new Date(a.created_at).toLocaleTimeString('pt-br',{hour:'2-digit',minute:'2-digit'})}</div>
            <button class="alerta-resolver" onclick="resolverAlerta(${a.id})">Resolver</button>
        </div>
    `).join('');
}

// ── Resolve alerta via fetch ──────────────────────────────
async function resolverAlerta(id) {
    await fetch(`/api/alertas/${id}/resolver`, { method: 'PATCH' });
    // o servidor vai mandar os alertas atualizados pelo WebSocket
}

// ── Toggle dropdown de alertas ────────────────────────────
function toggleAlertas() {
    const dd = document.getElementById('alertas-dropdown');
    if (!dd) return;
    const aberto = dd.style.display !== 'none';
    dd.style.display = aberto ? 'none' : 'block';
    if (!aberto) {
        // carrega alertas ao abrir
        fetch('/api/alertas')
            .then(r => r.json())
            .then(lista => renderizarAlertas(lista));
    }
}

function carregarIniciais() {
    const dados = window.__ULTIMAS__ || [];
    dados.forEach(d => {
        const ts = new Date(d.timestamp);
        const hora = ts.toLocaleTimeString('pt-br',{ hour:'2-digit', minute:'2-digit', second:'2-digit' });
        labels.push(hora);
        Object.keys(hist).forEach(k => hist[k].push(d[k] ?? null));
    });
    aplicarModo(modo);

    // popula os cards com a última leitura
    if (dados.length) {
        const u = dados[dados.length - 1];
        if (u.temperatura) document.getElementById('card-temp').textContent    = u.temperatura;
        if (u.umidade)     document.getElementById('card-umidade').textContent = u.umidade;
        if (u.gases)       document.getElementById('card-gases').textContent   = u.gases;
        if (u.CO)          document.getElementById('card-co').textContent      = u.CO;
    }
}

// ── WebSocket ─────────────────────────────────────────────
function conectarWS() {
    const ws = new WebSocket('ws://' + location.host);

    ws.onopen = () => console.log('Dashboard WS conectado!');

    ws.onmessage = (e) => {
        const msg = JSON.parse(e.data);

        if (msg.tipo === 'leitura') {
            adicionarLeitura(msg);       
        }
        if (msg.tipo === 'alertas') {
            atualizarBadgeAlerta(msg.total, msg.lista); // atualiza badge
        }
    };

    ws.onclose = () => setTimeout(conectarWS, 3000);
    ws.onerror = (e) => console.error('WS erro:', e);
}




// ── Inicia ────────────────────────────────────────────────
carregarIniciais();
conectarWS();
</script>
</body>
</html>