<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Recuperar Senha</title>
  <link rel="stylesheet" href="/css/recuperarSenha.css">>
</head>
<body>

<div class="card">

  <!-- esquerdo -->
  <div class="left">
    <div class="left-top">
      <h1>AIRGUARD</h1>
      <p>Monitoramento inteligente da qualidade do ar</p>
    </div>
    <div class="features">
      <div class="feature">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24"><path d="M3 8l7-5 4 3 4-3 3 5"/><path d="M3 8v10a1 1 0 001 1h16a1 1 0 001-1V8"/></svg>
        </div>
        <span>Qualidade do ar em tempo real</span>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <span>Segurança e confiabilidade</span>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <span>Dados precisos para decisões</span>
      </div>
    </div>
  </div>

  <!-- direito -->
  <div class="right">

    <!-- indicador de passos-->
    <div class="steps">
      <div class="step active" id="step1">
        <div class="step-circle">1</div>
        <span class="step-label">Informe o e-mail</span>
      </div>
      <div class="step-line" id="line1"></div>
      <div class="step inactive" id="step2">
        <div class="step-circle">2</div>
        <span class="step-label">Verifique o e-mail</span>
      </div>
      <div class="step-line" id="line2"></div>
      <div class="step inactive" id="step3">
        <div class="step-circle">3</div>
        <span class="step-label">Nova senha</span>
      </div>
    </div>

    
    <div id="form-state">
      <div class="right-header">
        <p class="subtitle">Informe o e-mail cadastrado para receber o link de recuperação de senha.</p>
      </div>

      <div class="info-box">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p>Enviaremos um link seguro para o e-mail informado. Verifique também a caixa de spam.</p>
      </div>

      <div class="field">
        <label for="email">Email</label>
        <div class="input-wrap">
          <span class="icon">
            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          <input type="email" id="email" placeholder="Digite seu email ou usuário" />
        </div>
      </div>

      <button class="btn-primary" onclick="sendRecovery()">Enviar link de recuperação</button>

      <p class="back-link">Lembrou a senha? <a href="/">Voltar ao login</a></p>
    </div>

    <div id="success-state" class="success-state">
      <div class="success-icon">
        <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <h2>E-mail enviado!</h2>
      <p>Enviamos o link de recuperação para <span class="email-highlight" id="sent-email"></span>. Verifique sua caixa de entrada.</p>
      <p class="resend">Não recebeu? <a onclick="resend()">Reenviar e-mail</a></p>
      <button class="btn-primary" style="margin-top:6px" onclick="window.location.href='/'">Voltar ao login</button>
    </div>

  </div>
</div>

<script>
  function sendRecovery() {
    const email = document.getElementById('email').value.trim();
    if (!email) {
      document.getElementById('email').focus();
      document.getElementById('email').style.boxShadow = '0 0 0 2.5px #e74c3c';
      setTimeout(() => document.getElementById('email').style.boxShadow = '', 1500);
      return;
    }

    // activate step 2
    document.getElementById('step2').className = 'step active';
    document.getElementById('line1').className = 'step-line done';

    document.getElementById('sent-email').textContent = email;
    document.getElementById('form-state').style.display = 'none';
    document.getElementById('success-state').style.display = 'flex';
  }

  function resend() {
    const el = document.querySelector('.resend');
    el.innerHTML = '<span style="color:#2856c8;font-weight:700">✓ E-mail reenviado!</span>';
    setTimeout(() => {
      el.innerHTML = 'Não recebeu? <a onclick="resend()">Reenviar e-mail</a>';
    }, 3000);
  }
</script>

</body>
</html>