<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AirGuard — Histórico</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/historico.css">
</head>
<body>
<div class="layout">

    <!-- ── Sidebar (idêntica às outras telas) ── -->
    <nav class="sidebar">
        <div class="sidebar-logo">
            <img src="/img/logo.png" alt="Logo" style="width: 32px; height: 32px; object-fit: contain;">
            <span class="sidebar-logo-text">AirGuard</span>
        </div>
            <a href="/home" class="nav-item">
               <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                   <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
                   <path d="M9 21V12h6v9"/>
               </svg>
               Dashboard
            </a>
            <a href="/historico" class="nav-item active">
               <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                   <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>
           </svg>
               Histórico
            </a>
            <a href="/sensores" class="nav-item">
               <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                   <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
               </svg>
               Sensores
            </a>
            <a href="/configuracoes" class="nav-item">
             <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
                </svg>
             Configurações
            </a>
        <div class="sidebar-footer">
            <div class="footer-status"><span class="dot-green"></span><span>Sistema Online</span></div>
            <div class="footer-quality">Qualidade do Ar: <strong>Boa</strong><span class="check-circle"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span></div>
        </div>
    </nav>

    <div class="main">



        

        <!-- header — igual às outras telas -->
        <header class="top-header">
           <div class="header-left">
                <h1>Historico</h1>
            </div>
            <div class="header-right">
                <div class="notif-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 01-3.46 0"/>
                    </svg>
                </div>
                <div class="user-wrapper">  
                <div class="user-info" id="user-btn" onclick="toggleUserMenu()">
                    <div class="user-avatar">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    
                    </div>
                    <!-- dados do usuário via EJS -->
                    <span><%= typeof usuario !== 'undefined' ? usuario : 'Usuário' %></span>
                    <span class="user-badge"><%= typeof perfil !== 'undefined' ? perfil.toUpperCase() : 'USR' %></span>
                    

                    <!-- seta para mostrar o menu -->
                    <svg class="seta" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                    
                </div>

                

                
  <div class="user-dropdown" id="user-dd">
    <div class="dd-head">
      <div class="dd-av">
        <%= (typeof usuario !== 'undefined' ? usuario : 'U').substring(0,2).toUpperCase() %>
      </div>
      <div>
        <div class="dd-name"><%= typeof usuario !== 'undefined' ? usuario : 'Usuário' %></div>
        <div class="dd-role"><%= typeof perfil !== 'undefined' ? perfil.toUpperCase() : 'USUÁRIO' %></div>
      </div>
    </div>
    <div class="dd-body">
      <a href="/configuracoes#perfil" class="dd-item" >
        <span class="dd-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        </span>
        Meu perfil
      </a>
      <a href="/configuracoes" class="dd-item">
        <span class="dd-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
          </svg>
        </span>
        Configurações
      </a>
      <div class="dd-sep"></div>
      <a class="dd-item danger" onclick="logout()">
        <span class="dd-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </span>
        Sair
      </a>
    </div>
  </div>
</div>





                
            </div>
        </header>





        <div class="content">

            <!-- Cards — recalculados a cada troca de período -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="label">Média Temperatura</div>
                    <div class="value-row">
                        <span class="value" id="card-temp">--</span>
                        <span class="unit">°C</span>
                    </div>
                    <div class="stat-sub" id="sub-temp">Selecione um período</div>
                </div>
                <div class="stat-card">
                    <div class="label">Média Umidade</div>
                    <div class="value-row">
                        <span class="value" id="card-umidade">--</span>
                        <span class="unit">%</span>
                    </div>
                    <div class="stat-sub" id="sub-umidade">Selecione um período</div>
                </div>
                <div class="stat-card">
                    <div class="label">Média CO</div>
                    <div class="value-row">
                        <span class="value" id="card-co">--</span>
                        <span class="unit">ppm</span>
                    </div>
                    <div class="stat-sub" id="sub-co">Selecione um período</div>
                </div>
                <div class="stat-card">
                    <div class="label">Média Gases</div>
                    <div class="value-row">
                        <span class="value" id="card-gases">--</span>
                        <span class="unit">ppm</span>
                    </div>
                    <div class="stat-sub" id="sub-gases">-- registros</div>
                </div>
            </div>

            <!-- Gráfico com abas de sensor e período no topo -->
            <div class="chart-card">
                <div class="chart-tabs">
                    <!-- abas de sensor -->
                    <button class="ctab active" onclick="mudarSensor('todos',this)">Todos</button>
                    <button class="ctab" onclick="mudarSensor('temperatura',this)">Temperatura</button>
                    <button class="ctab" onclick="mudarSensor('umidade',this)">Umidade</button>
                    <button class="ctab" onclick="mudarSensor('CO',this)">CO</button>
                    <button class="ctab" onclick="mudarSensor('gases',this)">Gases</button>
                    <div class="ctab-spacer"></div>
                    <!-- abas de período — cada uma busca da API -->
                    <button class="ptab" onclick="mudarPeriodo('24h',this)">24h</button>
                    <button class="ptab active" onclick="mudarPeriodo('7d',this)">7d</button>
                    <button class="ptab" onclick="mudarPeriodo('30d',this)">30d</button>
                    <button class="ptab" onclick="mudarPeriodo('90d',this)">90d</button>
                </div>
                <!-- indicador de carregamento -->
                <div id="chart-loading" style="display:none; text-align:center; padding:20px; color:#64748b; font-family:Nunito; font-size:13px; font-weight:700;">
                    Carregando dados...
                </div>
                <div class="chart-wrap">
                    <canvas id="graficoHistorico"></canvas>
                </div>
            </div>

        </div>
    </div>
</div>

<script>

function toggleUserMenu() {
    document.getElementById('user-btn').classList.toggle('open');
    document.getElementById('user-dd').classList.toggle('open');
}
document.addEventListener('click', e => {
    const w = document.querySelector('.user-wrapper');
    if (w && !w.contains(e.target)) {
        document.getElementById('user-btn')?.classList.remove('open');
        document.getElementById('user-dd')?.classList.remove('open');
    }
});




const COR = {
    temperatura: '#e74c3c',
    umidade:     '#2563eb',
    CO:          '#8b5cf6',
    gases:       '#f59e0b'
};

const LABEL_SENSOR = {
    temperatura: 'Temperatura (°C)',
    umidade:     'Umidade (%)',
    CO:          'CO — MQ7 (ppm)',
    gases:       'Gases — MQ135 (ppm)'
};

const DESCRICAO_PERIODO = {
    '24h': 'últimas 24 horas (média/hora)',
    '7d':  'últimos 7 dias (média/12h)',
    '30d': 'últimos 30 dias (média/dia)',
    '90d': 'últimos 90 dias (média/semana)'
};

let periodoAtual  = '7d';
let sensorAtual   = 'todos';
let pontosGlobais = [];  // guarda os pontos da última resposta da API





const ctx = document.getElementById('graficoHistorico').getContext('2d');
const grafico = new Chart(ctx, {
    type: 'line',
    data: { labels: [], datasets: [] },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 400 },
        plugins: {
            legend: {
                display: true,
                onClick: () => {},
                labels: { font: { family: 'Nunito', size: 12, weight: '700' }, color: '#64748b', usePointStyle: true }
            },
           
            tooltip: {
                callbacks: {
                    
                    afterLabel: (item) => {
                        const ponto = pontosGlobais[item.dataIndex];
                        return ponto ? `(${ponto.total_registros} registros na média)` : '';
                    }
                }
            }
        },

        scales: {
            x: {
                ticks: { font: { family: 'Nunito', size: 10 }, color: '#64748b', maxTicksLimit: 12 },
                grid:  { color: 'rgba(37,99,235,0.07)' }
            },
            y: {
                beginAtZero: false,
                ticks: { font: { family: 'Nunito', size: 10 }, color: '#64748b' },
                grid:  { color: 'rgba(37,99,235,0.07)' }
            }
        }
    }
});




function renderizarGrafico(pontos) {
    if (!pontos || pontos.length === 0) {
        grafico.data.labels   = [];
        grafico.data.datasets = [];
        grafico.update();
        return;
    }

    // labels vêm do campo `label` já formatado pelo SQLite
    const labels = pontos.map(p => p.label);

    const sensores = sensorAtual === 'todos'
        ? Object.keys(COR)
        : [sensorAtual];

    grafico.data.labels   = labels;
    grafico.data.datasets = sensores.map(s => ({
        label:           LABEL_SENSOR[s],
        data:            pontos.map(p => p[s] ?? null),
        borderColor:     COR[s],
        backgroundColor: COR[s] + '18',
        borderWidth:     2.5,
        pointRadius:     4,
        pointBackgroundColor: '#fff',
        pointBorderColor:    COR[s],
        pointBorderWidth:    2,
        tension:  0.4,
        fill:     sensores.length === 1
    }));

    grafico.update();
}


function atualizarCards(resumo, periodo) {
    if (!resumo) return;

    const desc = DESCRICAO_PERIODO[periodo] || periodo;

    document.getElementById('card-temp').textContent    = resumo.media_temp    ?? '--';
    document.getElementById('card-umidade').textContent = resumo.media_umidade ?? '--';
    document.getElementById('card-co').textContent      = resumo.media_co      ?? '--';
    document.getElementById('card-gases').textContent   = resumo.media_gases   ?? '--';

    document.getElementById('sub-temp').textContent    = desc;
    document.getElementById('sub-umidade').textContent = desc;
    document.getElementById('sub-co').textContent      = desc;

    const total = resumo.total_registros ?? '--';
    document.getElementById('sub-gases').textContent = `${total} registros no período`;
}


async function carregarHistorico() {
    // mostra loading
    document.getElementById('chart-loading').style.display = 'block';

    try {
        // endpoint retorna { pontos: [...], resumo: {...}, periodo: '7d' }
        const res  = await fetch(`/api/historico?periodo=${periodoAtual}`);
        const json = await res.json();

        pontosGlobais = json.pontos ?? [];

        // atualiza gráfico com os pontos agregados
        renderizarGrafico(pontosGlobais);

        // atualiza cards com o resumo calculado no banco
        atualizarCards(json.resumo, json.periodo);

    } catch (err) {
        console.error('[historico] Erro ao carregar:', err);
    } finally {
        document.getElementById('chart-loading').style.display = 'none';
    }
}



// troca de sensor — NÃO faz fetch, só re-renderiza com os dados que já tem
function mudarSensor(sensor, btn) {
    sensorAtual = sensor;
    document.querySelectorAll('.ctab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderizarGrafico(pontosGlobais); // usa dados já carregados
}


function mudarPeriodo(periodo, btn) {
    periodoAtual = periodo;
    document.querySelectorAll('.ptab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    carregarHistorico(); // busca dados agregados do novo período
}



//ancora do menu para passar direto para o perfil
window.addEventListener('load', () => {
    const ancora = window.location.hash.replace('#', '');

    if (ancora) {
        const btn = document.querySelector(`[onclick*="'${ancora}'"]`);
        if (btn) mudarAba(ancora, btn);
    }
});




function toggleUserMenu() {
    document.getElementById('user-btn').classList.toggle('open');
    document.getElementById('user-dd').classList.toggle('open');
}
document.addEventListener('click', e => {
    const w = document.querySelector('.user-wrapper');
    if (w && !w.contains(e.target)) {
        document.getElementById('user-btn')?.classList.remove('open');
        document.getElementById('user-dd')?.classList.remove('open');
    }
});


//opção de logout 
async function logout() {
    await fetch('/logout', { method: 'POST' });
    window.location.href = '/login';
}


carregarHistorico();
</script>
</body>
</html>