<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AirGuard — Histórico</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/historico.css">
</head>
<body>
<div class="layout">

    <!-- ── Sidebar ── -->
    <nav class="sidebar">
        <div class="sidebar-logo">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                <rect width="36" height="36" rx="10" fill="rgba(255,255,255,0.18)"/>
                <path d="M18 8 L26 12 L26 20 C26 24.4 22.4 28 18 29 C13.6 28 10 24.4 10 20 L10 12 Z" fill="white" opacity="0.9"/>
                <ellipse cx="18" cy="16" rx="6" ry="4" fill="#2563eb" opacity="0.7"/>
                <path d="M12 20 Q18 24 24 20" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            </svg>
            <span class="sidebar-logo-text">AirGuard</span>
        </div>

        <a href="/home"        class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><path d="M9 21V12h6v9"/>
            </svg>
            Dashboard
        </a>
        <a href="/historico"   class="nav-item active">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>
            </svg>
            Histórico
        </a>
        <a href="/sensores"    class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
            Sensores
        </a>
        <a href="/configuracoes" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
            </svg>
            Configurações
        </a>

        <div class="sidebar-footer">
            <div class="footer-status">
                <span class="dot-green"></span>
                <span>Sistema Online</span>
            </div>
            <div class="footer-quality">
                Qualidade do Ar: <strong>Boa</strong>
                <span class="check-circle">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </span>
            </div>
        </div>
    </nav>

    <!-- ── Main ── -->
    <div class="main">

        <header class="top-header">
            <h1>AirGuard — Histórico</h1>
            <div class="header-right">
                <button class="btn-export" onclick="exportarCSV()">↓ Exportar CSV</button>
                <div class="user-info">
                    <div class="user-avatar">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    </div>
                    <span><%= typeof usuario !== 'undefined' ? usuario : 'Usuário' %></span>
                    <span class="user-badge"><%= typeof perfil !== 'undefined' ? perfil.toUpperCase() : 'USR' %></span>
                </div>
            </div>
        </header>

        <div class="content">

            <!-- Cards resumo — IGUAL AO ORIGINAL -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="label">Média Temperatura</div>
                    <div class="value-row"><span class="value" id="media-temp">--</span><span class="unit">°C</span></div>
                    <div class="stat-sub">No período selecionado</div>
                </div>
                <div class="stat-card">
                    <div class="label">Média Umidade</div>
                    <div class="value-row"><span class="value" id="media-umidade">--</span><span class="unit">%</span></div>
                    <div class="stat-sub">No período selecionado</div>
                </div>
                <div class="stat-card">
                    <div class="label">Pior Qualidade do Ar</div>
                    <div class="value-row"><span class="value" id="pior-gases">--</span><span class="unit">ppm</span></div>
                    <div class="stat-sub" id="pior-data">--</div>
                </div>
                <div class="stat-card">
                    <div class="label">Total de Registros</div>
                    <div class="value-row"><span class="value" id="total-registros">--</span></div>
                    <div class="stat-sub">No período selecionado</div>
                </div>
            </div>

            <!-- Gráfico — IGUAL AO ORIGINAL -->
            <div class="chart-card">
                <div class="chart-tabs">
                    <button class="ctab active" data-sensor="todos"       onclick="mudarSensor('todos',this)">Todos</button>
                    <button class="ctab"         data-sensor="temperatura" onclick="mudarSensor('temperatura',this)">Temperatura</button>
                    <button class="ctab"         data-sensor="umidade"     onclick="mudarSensor('umidade',this)">Umidade</button>
                    <button class="ctab"         data-sensor="CO"          onclick="mudarSensor('CO',this)">CO</button>
                    <button class="ctab"         data-sensor="gases"       onclick="mudarSensor('gases',this)">Gases</button>
                    <div class="ctab-spacer"></div>
                    <button class="ptab" data-periodo="24h" onclick="mudarPeriodo('24h',this)">24h</button>
                    <button class="ptab active" data-periodo="7d" onclick="mudarPeriodo('7d',this)">7d</button>
                    <button class="ptab" data-periodo="30d" onclick="mudarPeriodo('30d',this)">30d</button>
                    <button class="ptab" data-periodo="90d" onclick="mudarPeriodo('90d',this)">90d</button>
                </div>
                <div class="chart-wrap">
                    <canvas id="graficoHistorico"></canvas>
                </div>
            </div>

            <!-- ── NOVO: Alertas ── -->
            <div class="table-card">
                <div class="table-header">
                    <h2>Configurar Alertas</h2>
                    <button class="btn-export" onclick="document.getElementById('form-alerta').style.display='block'">+ Novo Alerta</button>
                </div>

                <!-- Formulário -->
                <div id="form-alerta" style="display:none; padding: 16px 0 8px; border-bottom: 1px solid #e2e8f0; margin-bottom: 12px;">
                    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:12px;">
                        <div style="display:flex; flex-direction:column; gap:4px; flex:1; min-width:130px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Sensor</label>
                            <select id="al-sensor" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;">
                                <option value="temperatura">Temperatura (°C)</option>
                                <option value="umidade">Umidade (%)</option>
                                <option value="gases">Gases MQ135 (ppm)</option>
                                <option value="CO">CO MQ7 (ppm)</option>
                            </select>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px; flex:1; min-width:130px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Condição</label>
                            <select id="al-cond" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;">
                                <option value="maior">Maior que (&gt;)</option>
                                <option value="menor">Menor que (&lt;)</option>
                            </select>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px; flex:1; min-width:100px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Valor</label>
                            <input id="al-valor" type="number" placeholder="ex: 400" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;"/>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px; flex:1; min-width:130px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Severidade</label>
                            <select id="al-sev" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;">
                                <option value="aviso">⚠ Aviso</option>
                                <option value="critico">🔴 Crítico</option>
                            </select>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px; flex:2; min-width:160px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Descrição</label>
                            <input id="al-desc" type="text" placeholder="ex: CO acima do limite" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;"/>
                        </div>
                    </div>
                    <div style="display:flex; gap:8px; justify-content:flex-end;">
                        <button onclick="document.getElementById('form-alerta').style.display='none'" style="background:#fff; border:1px solid #e2e8f0; color:#64748b; font-family:Nunito,sans-serif; font-size:13px; font-weight:700; padding:7px 16px; border-radius:8px; cursor:pointer;">Cancelar</button>
                        <button onclick="salvarAlerta()" style="background:#2563eb; border:none; color:#fff; font-family:Nunito,sans-serif; font-size:13px; font-weight:800; padding:7px 18px; border-radius:8px; cursor:pointer;">Salvar</button>
                    </div>
                </div>

                <!-- Lista de alertas -->
                <div id="alertas-lista">
                    <div style="text-align:center; color:#94a3b8; font-size:13px; font-weight:600; padding:16px;">Nenhum alerta configurado.</div>
                </div>

                <!-- Alertas disparados -->
                <div id="alertas-disparados" style="display:none; margin-top:12px; border-top:1px solid #e2e8f0; padding-top:12px;">
                    <div style="font-size:13px; font-weight:800; color:#1e3a5f; margin-bottom:8px;">🔔 Alertas Disparados</div>
                    <div id="lista-disparados"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
let dadosGlobais = [];
let periodoAtual = '7d';
let sensorAtual  = 'todos';
let alertas      = JSON.parse(localStorage.getItem('airguard_alertas') || '[]');

const ctx = document.getElementById('graficoHistorico').getContext('2d');
const grafico = new Chart(ctx, {
    type: 'line',
    data: { labels: [], datasets: [] },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        plugins: { legend: { display: true, labels: { font: { family: 'Nunito', size: 12, weight: '700' }, color: '#64748b', usePointStyle: true } } },
        scales: {
            x: { ticks: { font: { family: 'Nunito', size: 10 }, color: '#64748b', maxTicksLimit: 10 }, grid: { color: 'rgba(37,99,235,0.07)' } },
            y: { beginAtZero: false, ticks: { font: { family: 'Nunito', size: 10 }, color: '#64748b' }, grid: { color: 'rgba(37,99,235,0.07)' } }
        }
    }
});

const COR   = { temperatura: '#e74c3c', umidade: '#2563eb', gases: '#f59e0b', CO: '#8b5cf6' };
const LABEL = { temperatura: 'Temperatura (°C)', umidade: 'Umidade (%)', gases: 'Gases (ppm)', CO: 'CO (ppm)' };
const SNOME = { temperatura: 'Temperatura', umidade: 'Umidade', gases: 'Gases MQ135', CO: 'CO MQ7' };
const COND  = { maior: '>', menor: '<' };

function classificar(valor) {
    if (valor > 700) return { label: 'Ruim',     cls: 'bad' };
    if (valor > 400) return { label: 'Moderada', cls: 'moderate' };
    return                   { label: 'Boa',      cls: 'good' };
}

function formatarData(ts) {
    const d = new Date(ts);
    return d.toLocaleDateString('pt-br', { day: '2-digit', month: 'short' })
         + ' ' + d.toLocaleTimeString('pt-br', { hour: '2-digit', minute: '2-digit' });
}

function media(arr) {
    const v = arr.filter(x => x != null && !isNaN(x));
    return v.length ? (v.reduce((a,b) => a+b, 0) / v.length).toFixed(1) : '--';
}

function renderizar(dados) {
    dadosGlobais = dados;
    if (!dados || dados.length === 0) { grafico.data.labels = []; grafico.data.datasets = []; grafico.update(); return; }

    document.getElementById('media-temp').textContent     = media(dados.map(d => d.temperatura));
    document.getElementById('media-umidade').textContent  = media(dados.map(d => d.umidade));
    document.getElementById('total-registros').textContent = dados.length;

    const piorGases = Math.max(...dados.map(d => d.gases ?? 0));
    const piorDado  = dados.find(d => (d.gases ?? 0) === piorGases);
    document.getElementById('pior-gases').textContent = piorGases || '--';
    if (piorDado) document.getElementById('pior-data').textContent = formatarData(piorDado.timestamp ?? Date.now());

    const labels  = dados.map(d => formatarData(d.timestamp ?? Date.now()));
    const configs = sensorAtual === 'todos'
        ? Object.keys(COR).map(k => ({ campo: k, label: LABEL[k], cor: COR[k] }))
        : [{ campo: sensorAtual, label: LABEL[sensorAtual], cor: COR[sensorAtual] }];

    grafico.data.labels   = labels;
    grafico.data.datasets = configs.map(c => ({
        label: c.label, data: dados.map(d => d[c.campo] ?? null),
        borderColor: c.cor, backgroundColor: c.cor + '15',
        borderWidth: 2.5, pointRadius: 3, tension: 0.4, fill: configs.length === 1
    }));
    grafico.update();
    verificarAlertas(dados);
}

async function carregarHistorico() {
    try {
        const res  = await fetch(`/api/leituras/historico?periodo=${periodoAtual}&sensor=${sensorAtual}`);
        const json = await res.json();
        renderizar(json.dados ?? json);
    } catch (err) { console.error('Erro ao carregar:', err); }
}

function mudarSensor(sensor, btn) {
    sensorAtual = sensor;
    document.querySelectorAll('.ctab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderizar(dadosGlobais);
}

function mudarPeriodo(periodo, btn) {
    periodoAtual = periodo;
    document.querySelectorAll('.ptab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    carregarHistorico();
}

function exportarCSV() {
    if (!dadosGlobais.length) return;
    const header = 'Data/Hora,Temperatura,Umidade,Gases,CO\n';
    const linhas = dadosGlobais.map(d =>
        `"${formatarData(d.timestamp ?? Date.now())}",${d.temperatura ?? ''},${d.umidade ?? ''},${d.gases ?? ''},${d.CO ?? ''}`
    ).join('\n');
    const blob = new Blob([header + linhas], { type: 'text/csv' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
    a.download = `airguard-${periodoAtual}.csv`; a.click();
}

// ── Alertas ──────────────────────────────────────────────
function renderAlertas() {
    const lista = document.getElementById('alertas-lista');
    if (alertas.length === 0) {
        lista.innerHTML = '<div style="text-align:center; color:#94a3b8; font-size:13px; font-weight:600; padding:16px;">Nenhum alerta configurado.</div>';
        return;
    }
    lista.innerHTML = alertas.map((a, i) => `
        <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 14px; border-radius:10px; margin-bottom:8px; background:${a.severidade==='critico'?'#fff5f5':'#fffbeb'}; border-left:4px solid ${a.severidade==='critico'?'#ef4444':'#f59e0b'};">
            <div style="display:flex; align-items:center; gap:10px;">
                <span style="font-size:18px;">${a.severidade==='critico'?'🔴':'⚠️'}</span>
                <div>
                    <div style="font-size:13px; font-weight:800; color:#1e3a5f;">${a.desc || SNOME[a.sensor]}</div>
                    <div style="font-size:12px; color:#64748b; font-weight:600;">${SNOME[a.sensor]} ${COND[a.cond]} ${a.valor} — <span style="color:${a.severidade==='critico'?'#dc2626':'#b45309'}">${a.severidade==='critico'?'Crítico':'Aviso'}</span></div>
                </div>
            </div>
            <div style="display:flex; align-items:center; gap:8px;">
                <span style="font-size:12px; font-weight:700; color:${a.ativo?'#16a34a':'#94a3b8'}">${a.ativo?'● Ativo':'○ Inativo'}</span>
                <button onclick="toggleAlerta(${i})" style="background:#fff; border:1px solid #e2e8f0; color:#64748b; font-family:Nunito,sans-serif; font-size:12px; font-weight:700; padding:4px 10px; border-radius:6px; cursor:pointer;">${a.ativo?'Desativar':'Ativar'}</button>
                <button onclick="removerAlerta(${i})" style="background:#fff; border:1px solid #fee2e2; color:#ef4444; font-family:Nunito,sans-serif; font-size:12px; font-weight:800; padding:4px 10px; border-radius:6px; cursor:pointer;">✕</button>
            </div>
        </div>
    `).join('');
}

function salvarAlerta() {
    const valor = parseFloat(document.getElementById('al-valor').value);
    if (isNaN(valor)) { alert('Informe um valor numérico.'); return; }
    alertas.push({
        sensor: document.getElementById('al-sensor').value,
        cond:   document.getElementById('al-cond').value,
        valor,
        severidade: document.getElementById('al-sev').value,
        desc:   document.getElementById('al-desc').value.trim(),
        ativo: true
    });
    localStorage.setItem('airguard_alertas', JSON.stringify(alertas));
    renderAlertas();
    document.getElementById('form-alerta').style.display = 'none';
    document.getElementById('al-valor').value = '';
    document.getElementById('al-desc').value  = '';
}

function removerAlerta(i) { alertas.splice(i,1); localStorage.setItem('airguard_alertas', JSON.stringify(alertas)); renderAlertas(); }
function toggleAlerta(i)  { alertas[i].ativo = !alertas[i].ativo; localStorage.setItem('airguard_alertas', JSON.stringify(alertas)); renderAlertas(); }

function verificarAlertas(dados) {
    if (!dados || dados.length === 0) return;
    const ultimo = dados[dados.length - 1];
    const disparados = alertas.filter(a => a.ativo).filter(a => {
        const val = ultimo[a.sensor];
        if (val == null) return false;
        return (a.cond === 'maior' && val > a.valor) || (a.cond === 'menor' && val < a.valor);
    }).map(a => ({ ...a, valorAtual: ultimo[a.sensor] }));

    const secao = document.getElementById('alertas-disparados');
    const lista = document.getElementById('lista-disparados');
    if (disparados.length > 0) {
        secao.style.display = 'block';
        lista.innerHTML = disparados.map(d => `
            <div style="display:flex; align-items:center; gap:10px; padding:10px 14px; border-radius:10px; margin-bottom:6px; background:${d.severidade==='critico'?'#fff1f2':'#fffbeb'}; border:1px solid ${d.severidade==='critico'?'#fca5a5':'#fcd34d'}; animation: piscar 1.5s infinite;">
                <span>${d.severidade==='critico'?'🔴':'⚠️'}</span>
                <span style="font-size:13px; font-weight:700; color:#1e3a5f; flex:1;">${d.desc || SNOME[d.sensor]} — valor atual: <strong>${d.valorAtual}</strong> (limite: ${COND[d.cond]} ${d.valor})</span>
                <span style="font-size:10px; font-weight:800; padding:3px 10px; border-radius:20px; background:${d.severidade==='critico'?'#fee2e2':'#fef3c7'}; color:${d.severidade==='critico'?'#dc2626':'#b45309'}">${d.severidade==='critico'?'CRÍTICO':'AVISO'}</span>
            </div>
        `).join('');
    } else {
        secao.style.display = 'none';
    }
}

renderAlertas();
carregarHistorico();
</script>
</body>
</html>
