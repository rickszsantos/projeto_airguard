<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AirGuard - Sensores</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/sensor.css">
</head>
<body>

<div class="layout">

    <!-- ── Sidebar ── -->
    <nav class="sidebar">
        <div class="sidebar-logo">
           <img src="/img/logo.png" alt="Logo" style="width: 32px; height: 32px; object-fit: contain;">
            <span class="sidebar-logo-text">AirGuard</span>
        </div>

        <a href="/home" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
                <path d="M9 21V12h6v9"/>
            </svg>
            Dashboard
        </a>

        <a href="/historico" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/>
                <path d="M12 7v5l3 3"/>
            </svg>
            Histórico
        </a>

        <a href="/sensores" class="nav-item active">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18M9 21V9"/>
            </svg>
            Sensores
        </a>

        <a href="/configuracoes" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
            </svg>
            Configurações
        </a>

        <div class="sidebar-footer">
            <div class="footer-status">
                <span class="dot-green"></span>
                <span>Sistema Online</span>
            </div>
            <div class="footer-quality">
                Qualidade do Ar: <strong>Boa</strong>
                <span class="check-circle">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </span>
            </div>
        </div>
    </nav>

    <!-- ── Main ── -->
    <div class="main">





        <header class="top-header">
            <div class="header-left">
                <h1>Sensores</h1>
            </div>
            <div class="header-right">
                <div class="notif-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 01-3.46 0"/>
                    </svg>
                </div>
                <div class="user-wrapper">  
                <div class="user-info" id="user-btn" onclick="toggleUserMenu()">
                    <div class="user-avatar">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    
                    </div>
                    <!-- dados do usuário via EJS -->
                    <span><%= typeof usuario !== 'undefined' ? usuario : 'Usuário' %></span>
                    <span class="user-badge"><%= typeof perfil !== 'undefined' ? perfil.toUpperCase() : 'USR' %></span>
                    

                    <!-- seta para mostrar o menu -->
                    <svg class="seta" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                    
                </div>

                

                
  <div class="user-dropdown" id="user-dd">
    <div class="dd-head">
      <div class="dd-av">
        <%= (typeof usuario !== 'undefined' ? usuario : 'U').substring(0,2).toUpperCase() %>
      </div>
      <div>
        <div class="dd-name"><%= typeof usuario !== 'undefined' ? usuario : 'Usuário' %></div>
        <div class="dd-role"><%= typeof perfil !== 'undefined' ? perfil.toUpperCase() : 'USUÁRIO' %></div>
      </div>
    </div>
    <div class="dd-body">
      <a href="/configuracoes#perfil" class="dd-item" >
        <span class="dd-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        </span>
        Meu perfil
      </a>
      <a href="/configuracoes" class="dd-item">
        <span class="dd-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
          </svg>
        </span>
        Configurações
      </a>
      <div class="dd-sep"></div>
      <a class="dd-item danger" onclick="logout()">
        <span class="dd-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </span>
        Sair
      </a>
    </div>
  </div>
</div>





                
            </div>
        </header>





        <div class="content">

            <!-- Page title + busca -->
            <div class="page-top">
                <div>

                    <p class="page-sub">Gerencie suas estações e sensores</p>
                </div>
                <div class="page-actions">
                    <div class="search-box">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input type="text" placeholder="Buscar estação..." id="busca-input"/>
                    </div>
                    <button class="btn-nova" id="btn-nova-estacao" onclick="tentarCriarEstacao()">+ Nova Estação</button>
                </div>
            </div>

            <!-- Cards resumo -->
            <div class="summary-grid">
                <div class="summary-card">
                    <div class="summary-icon icon-blue">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
                            <line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/>
                        </svg>
                    </div>
                    <div>
                        <div class="summary-label">Estações Ativas</div>
                        <div class="summary-value" id="estacoes-ativas">--</div>
                        <div class="summary-sub" id="estacoes-total">de -- estações</div>
                    </div>
                </div>
                <div class="summary-card">
                    <div class="summary-icon icon-green">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1114 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2"/>
                        </svg>
                    </div>
                    <div>
                        <div class="summary-label">Sensores Ativos</div>
                        <div class="summary-value" id="sensores-ativos">--</div>
                        <div class="summary-sub" id="sensores-total">de -- sensores</div>
                    </div>
                </div>
                <div class="summary-card">
                    <div class="summary-icon icon-orange">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                        </svg>
                    </div>
                    <div>
                        <div class="summary-label">Leituras Hoje</div>
                        <div class="summary-value" id="leituras-hoje">--</div>
                        <div class="summary-sub">Total de leituras</div>
                    </div>
                </div>
                <div class="summary-card">
                    <div class="summary-icon icon-purple">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 010 8.49m-8.48-.01a6 6 0 010-8.49m11.31-2.82a10 10 0 010 14.14m-14.14 0a10 10 0 010-14.14"/>
                        </svg>
                    </div>
                    <div>
                        <div class="summary-label">Status da Rede</div>
                        <div class="summary-value green-text">Bom</div>
                        <div class="summary-sub">Todos conectados</div>
                    </div>
                </div>
            </div>

            <!-- Lista de estações -->
            <div class="estacoes-lista" id="estacoes-lista">
                <div class="loading-msg">Carregando estações...</div>
            </div>

            <!-- Paginação -->
            <div class="paginacao">
                
                <span class="page-info" id="page-info">Mostrando 1 a 0 de 0 estações</span>
            </div>

            <!-- ── Configurar Alertas ── -->
            <div class="table-card" style="margin-top:4px;">
                <div class="table-header">
                    <h2>Configurar Alertas</h2>
                    <button class="btn-nova" onclick="document.getElementById('form-alerta').style.display='block'">+ Novo Alerta</button>
                </div>

                <!-- Formulário -->
                <div id="form-alerta" style="display:none; padding:16px 0 8px; border-bottom:1px solid #e2e8f0; margin-bottom:12px;">
                    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:12px;">
                        <div style="display:flex; flex-direction:column; gap:4px; flex:1; min-width:130px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Sensor</label>
                            <select id="al-sensor" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;">
                                <option value="temperatura">Temperatura (°C)</option>
                                <option value="umidade">Umidade (%)</option>
                                <option value="gases">Gases MQ135 (ppm)</option>
                                <option value="CO">CO MQ7 (ppm)</option>
                            </select>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px; flex:1; min-width:130px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Condição</label>
                            <select id="al-cond" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;">
                                <option value="maior">Maior que (&gt;)</option>
                                <option value="menor">Menor que (&lt;)</option>
                            </select>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px; flex:1; min-width:100px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Valor</label>
                            <input id="al-valor" type="number" placeholder="ex: 400" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;"/>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px; flex:1; min-width:130px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Severidade</label>
                            <select id="al-sev" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;">
                                <option value="aviso">⚠ Aviso</option>
                                <option value="critico">🔴 Crítico</option>
                            </select>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:4px; flex:2; min-width:160px;">
                            <label style="font-size:11px; font-weight:800; color:#2563eb; text-transform:uppercase;">Descrição</label>
                            <input id="al-desc" type="text" placeholder="ex: CO acima do limite" style="border:1px solid #e2e8f0; border-radius:8px; padding:7px 10px; font-family:Nunito,sans-serif; font-size:13px; font-weight:600; outline:none;"/>
                        </div>
                    </div>
                    <div style="display:flex; gap:8px; justify-content:flex-end;">
                        <button onclick="document.getElementById('form-alerta').style.display='none'" style="background:#fff; border:1px solid #e2e8f0; color:#64748b; font-family:Nunito,sans-serif; font-size:13px; font-weight:700; padding:7px 16px; border-radius:8px; cursor:pointer;">Cancelar</button>
                        <button onclick="salvarAlerta()" style="background:#2563eb; border:none; color:#fff; font-family:Nunito,sans-serif; font-size:13px; font-weight:800; padding:7px 18px; border-radius:8px; cursor:pointer;">Salvar</button>
                    </div>
                </div>

                <!-- Lista de alertas -->
                <div id="alertas-lista">
                    <div style="text-align:center; color:#94a3b8; font-size:13px; font-weight:600; padding:16px;">Nenhum alerta configurado.</div>
                </div>

                <!-- Alertas disparados -->
                <div id="alertas-disparados" style="display:none; margin-top:12px; border-top:1px solid #e2e8f0; padding-top:12px;">
                    <div style="font-size:13px; font-weight:800; color:#1e3a5f; margin-bottom:8px;">🔔 Alertas Disparados</div>
                    <div id="lista-disparados"></div>
                </div>
            </div>

        </div>
    </div>
</div>












<div class="modal-overlay" id="modal-estacao">
    <div class="modal-box">

        <div class="modal-header">
            <div class="modal-header-info">
                <div class="modal-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="14" rx="2"/>
                        <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
                    </svg>
                </div>
                <div>
                    <p class="modal-title">Nova Estação</p>
                    <p class="modal-sub">Preencha os dados para cadastrar</p>
                </div>
            </div>
            <button class="modal-fechar" onclick="fecharModal()">✕</button>
        </div>

        <div class="modal-body">

            <div class="modal-field">
                <label>Nome da estação <span class="obrigatorio">*</span></label>
                <input type="text" id="m-nome" placeholder="Ex: Sala Principal"/>
            </div>

            <div class="modal-field">
                <label>Descrição</label>
                <input type="text" id="m-desc" placeholder="Opcional"/>
            </div>

            <div class="modal-linha-dupla">
                <div class="modal-field">
                    <label>Latitude</label>
                    <input type="number" id="m-lat" placeholder="-23.5505" step="0.0001"/>
                </div>
                <div class="modal-field">
                    <label>Longitude</label>
                    <input type="number" id="m-lng" placeholder="-46.6333" step="0.0001"/>
                </div>
            </div>

            <div class="modal-field">
                <label>Intervalo de leitura (segundos)</label>
                <div class="modal-intervalo">
                    <input type="number" id="m-intervalo" value="5" min="1"/>
                    <span class="modal-unit">segundos</span>
                </div>
            </div>

            <!-- info sobre sensores criados automaticamente -->
            <div class="modal-info">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                Os sensores <strong>DHT22</strong>, <strong>MQ7</strong> e <strong>MQ135</strong> serão cadastrados automaticamente.
            </div>

            <div class="modal-erro" id="modal-erro" style="display:none"></div>

        </div>

        <div class="modal-footer">
            <button class="btn-cancelar" onclick="fecharModal()">Cancelar</button>
            <button class="btn-salvar-modal" id="btn-salvar-estacao" onclick="salvarEstacao()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
                    <polyline points="17 21 17 13 7 13 7 21"/>
                    <polyline points="7 3 7 8 15 8"/>
                </svg>
                Salvar Estação
            </button>
        </div>

    </div>
</div>





<div class="modal-overlay" id="modal-editar">
    <div class="modal-box">

        <div class="modal-header">
            <div class="modal-header-info">
                <div class="modal-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                </div>
                <div>
                    <p class="modal-title">Editar Estação</p>
                    <p class="modal-sub" id="editar-sub">Altere os dados da estação</p>
                </div>
            </div>
            <button class="modal-fechar" onclick="fecharEditar()">✕</button>
        </div>

        <div class="modal-body">

            <input type="hidden" id="editar-id"/>

            <div class="modal-field">
                <label>Nome da estação <span class="obrigatorio">*</span></label>
                <input type="text" id="editar-nome" placeholder="Ex: Sala Principal"/>
            </div>

            <div class="modal-field">
                <label>Descrição</label>
                <input type="text" id="editar-desc" placeholder="Opcional"/>
            </div>

            <div class="modal-linha-dupla">
                <div class="modal-field">
                    <label>Latitude</label>
                    <input type="number" id="editar-lat" placeholder="-23.5505" step="0.0001"/>
                </div>
                <div class="modal-field">
                    <label>Longitude</label>
                    <input type="number" id="editar-lng" placeholder="-46.6333" step="0.0001"/>
                </div>
            </div>

            <div class="modal-field">
                <label>Intervalo de leitura (segundos)</label>
                <div class="modal-intervalo">
                    <input type="number" id="editar-intervalo" value="5" min="1"/>
                    <span class="modal-unit">segundos</span>
                </div>
            </div>

            <div class="modal-info" id="editar-info-permissao" style="display:none; background:#fff7ed; border-color:#fed7aa; color:#b45309">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                    <path d="M7 11V7a5 5 0 0110 0v4"/>
                </svg>
                <span>Você não tem permissão para editar estações. Necessário nível Admin ou superior.</span>
            </div>

            <div class="modal-erro" id="editar-erro" style="display:none"></div>
        </div>

        <div class="modal-footer">
            <button class="btn-cancelar" onclick="fecharEditar()">Cancelar</button>
            <button class="btn-salvar-modal" id="btn-salvar-editar" onclick="salvarEdicao()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
                    <polyline points="17 21 17 13 7 13 7 21"/>
                    <polyline points="7 3 7 8 15 8"/>
                </svg>
                Salvar Alterações
            </button>
        </div>

    </div>
</div>




<div class="modal-overlay" id="modal-excluir">
    <div class="modal-box" style="max-width:420px">
        <div class="modal-header">
            <div class="modal-header-info">
                <div class="modal-icon" style="background:#fee2e2; color:#dc2626">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                        <path d="M10 11v6M14 11v6"/>
                    </svg>
                </div>
                <div>
                    <p class="modal-title" style="color:#dc2626">Excluir Estação</p>
                    <p class="modal-sub" id="excluir-nome-estacao">Esta ação não pode ser desfeita</p>
                </div>
            </div>
            <button class="modal-fechar" onclick="fecharExcluir()">✕</button>
        </div>
        <div class="modal-body">
            <div class="modal-info" style="background:#fff5f5; border-color:#fecaca; color:#dc2626">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                Todos os sensores e leituras serão removidos permanentemente.
            </div>
            <div class="modal-erro" id="excluir-erro" style="display:none"></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancelar" onclick="fecharExcluir()">Cancelar</button>
            <button class="btn-excluir-confirm" id="btn-confirmar-excluir" onclick="confirmarExclusao()">
                🗑 Confirmar Exclusão
            </button>
        </div>
    </div>
</div>








<script src="/js/permissao.js"></script>
<script>
// ══════════════════════════════════════════════════════
const PERFIL_USUARIO = '<%= typeof perfil !== "undefined" ? perfil : "funcionario" %>';
const NIVEL          = { funcionario: 1, admin: 2, superadmin: 3 };
const podeEditar     = (NIVEL[PERFIL_USUARIO] || 0) >= NIVEL['admin'];
const podeExcluir    = (NIVEL[PERFIL_USUARIO] || 0) >= NIVEL['admin'];
const podeStatus     = (NIVEL[PERFIL_USUARIO] || 0) >= NIVEL['admin'];

function temPermissao(nivelMinimo) {
    return (NIVEL[PERFIL_USUARIO] || 0) >= (NIVEL[nivelMinimo] || 99);
}

// ══════════════════════════════════════════════════════
// MENU DO USUÁRIO
// ══════════════════════════════════════════════════════
function toggleUserMenu() {
    document.getElementById('user-btn').classList.toggle('open');
    document.getElementById('user-dd').classList.toggle('open');
}

document.addEventListener('click', e => {
    const w = document.querySelector('.user-wrapper');
    if (w && !w.contains(e.target)) {
        document.getElementById('user-btn')?.classList.remove('open');
        document.getElementById('user-dd')?.classList.remove('open');
    }
});

async function logout() {
    await fetch('/logout', { method: 'POST' });
    window.location.href = '/login';
}

// ══════════════════════════════════════════════════════
// TOAST DE AVISO DE PERMISSÃO
// ══════════════════════════════════════════════════════
function mostrarAvisoPermissao(mensagem) {
    let toast = document.getElementById('toast-permissao');
    if (!toast) {
        toast = document.createElement('div');
        toast.id = 'toast-permissao';
        toast.style.cssText = `
            position:fixed; bottom:24px; left:50%; transform:translateX(-50%);
            background:#1e3a5f; color:#fff; padding:12px 24px; border-radius:10px;
            font-family:Nunito,sans-serif; font-size:13px; font-weight:700;
            box-shadow:0 4px 20px rgba(0,0,0,0.2); z-index:9999;
            opacity:0; transition:opacity 0.2s;
            display:flex; align-items:center; gap:10px;
        `;
        document.body.appendChild(toast);
    }
    toast.innerHTML = `
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
        </svg>
        ${mensagem}
    `;
    toast.style.opacity = '1';
    setTimeout(() => { toast.style.opacity = '0'; }, 3000);
}

// ══════════════════════════════════════════════════════
// ESTAÇÕES — renderização
// ══════════════════════════════════════════════════════
const API_ESTACOES = '/api/estacoes';

function statusBadge(status) {
    const map = {
        'ativa':      { label:'Ativa',      cls:'badge-ativa' },
        'inativa':    { label:'Inativa',    cls:'badge-inativa' },
        'manutencao': { label:'Manutenção', cls:'badge-manutencao' }
    };
    const s = map[status?.toLowerCase()] ?? { label: status, cls: 'badge-inativa' };
    return `<span class="status-badge ${s.cls}">${s.label}</span>`;
}

function sensorStatusDot(status) {
    const ativo = status?.toLowerCase() === 'ativo';
    return `<span class="sensor-dot ${ativo?'dot-ativo':'dot-inativo'}"></span>
            <span class="${ativo?'text-ativo':'text-inativo'}">${ativo?'Ativo':'Inativo'}</span>`;
}

function iconEstacao(nome) {
    return `<div class="estacao-icon" style="background:#2563eb22; border:2px solid #2563eb44">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2"/>
            <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
        </svg>
    </div>`;
}

function botoeEstacao(id, status, est) {
    const ativa = (status || '').toLowerCase() === 'ativa';

    // ativar/desativar — só admin ou superior
    let btnToggle;
    if (podeStatus) {
        btnToggle = ativa
            ? `<button class="btn-acao btn-desativar" onclick="alterarStatus(${id},'inativa',this)">⏻ Desativar</button>`
            : `<button class="btn-acao btn-ativar"    onclick="alterarStatus(${id},'ativa',this)">⏻ Ativar</button>`;
    } else {
        btnToggle = ativa
            ? `<button class="btn-acao btn-desativar sem-permissao" onclick="mostrarAvisoPermissao('Desativar estações requer nível Admin ou superior.')">⏻ Desativar</button>`
            : `<button class="btn-acao btn-ativar sem-permissao"    onclick="mostrarAvisoPermissao('Ativar estações requer nível Admin ou superior.')">⏻ Ativar</button>`;
    }

    // editar — admin ou superior
    const btnEditar = podeEditar
        ? `<button class="btn-acao btn-editar"  onclick='abrirEditar(${JSON.stringify(est)})'>✏ Editar</button>`
        : `<button class="btn-acao btn-editar sem-permissao" onclick="mostrarAvisoPermissao('Editar estações requer nível Admin ou superior.')" title="Sem permissão">✏ Editar</button>`;

    // excluir — admin ou superior
    const btnExcluir = podeExcluir
        ? `<button class="btn-acao btn-excluir" onclick="abrirModalExcluir(${id}, '${(est.nome||'').replace(/'/g,"\\'")}')">🗑 Excluir</button>`
        : `<button class="btn-acao btn-excluir sem-permissao" onclick="mostrarAvisoPermissao('Excluir estações requer nível Admin ou superior.')" title="Sem permissão">🗑 Excluir</button>`;

    return btnEditar + btnExcluir + btnToggle;
}

function renderEstacoes(estacoes) {
    const lista = document.getElementById('estacoes-lista');
    if (!estacoes || estacoes.length === 0) {
        lista.innerHTML = '<div class="loading-msg">Nenhuma estação encontrada.</div>';
        return;
    }
    lista.innerHTML = estacoes.map(est => `
        <div class="estacao-card">
            <div class="estacao-esq">
                ${iconEstacao(est.nome)}
                <div class="estacao-info">
                    <div class="estacao-nome-row"><strong>${est.nome}</strong>${statusBadge(est.status)}</div>
                    <div class="estacao-meta">ID: ${est.id ?? '--'}</div>
                    <div class="estacao-meta">📍 ${est.latitude ?? '--'}, ${est.longitude ?? '--'}</div>
                    <div class="estacao-meta">Intervalo: ${(est.intervalo_leitura || 5000) / 1000}s</div>
                    ${est.descricao ? `<div class="estacao-meta">📝 ${est.descricao}</div>` : ''}
                </div>
            </div>
            <div class="estacao-dir">
                <div class="sensores-lista-inline">
                    <div class="sensores-header">Sensores</div>
                    ${(est.sensores?.length > 0 ? est.sensores : [
                        { tipo:'DHT22', descricao:'Temperatura e Umidade', status: est.status==='ativa'?'ativo':'inativo' },
                        { tipo:'MQ7',   descricao:'Monóxido de Carbono',   status: est.status==='ativa'?'ativo':'inativo' },
                        { tipo:'MQ135', descricao:'Qualidade do Ar',       status: est.status==='ativa'?'ativo':'inativo' },
                    ]).map(s => `
                        <div class="sensor-row">
                            <span class="sensor-nome">${s.tipo}${s.descricao?' — '+s.descricao:''}</span>
                            <span class="sensor-status">${sensorStatusDot(s.status)}</span>
                            <span class="sensor-hora">-</span>
                        </div>`).join('')}
                </div>
                <div class="estacao-botoes">${botoeEstacao(est.id, est.status, est)}</div>
            </div>
        </div>`).join('');
    document.getElementById('page-info').textContent = `Mostrando 1 a ${estacoes.length} de ${estacoes.length} estações`;
}

async function carregarSensores() {
    try {
        const res      = await fetch(API_ESTACOES);
        const json     = await res.json();
        const estacoes = json.estacoes ?? json;
        const ativas   = estacoes.filter(e => e.status?.toLowerCase() === 'ativa').length;

        document.getElementById('estacoes-ativas').textContent = ativas;
        document.getElementById('estacoes-total').textContent  = `de ${estacoes.length} estações`;
        document.getElementById('sensores-ativos').textContent = ativas * 3;
        document.getElementById('sensores-total').textContent  = `de ${estacoes.length * 3} sensores`;
        document.getElementById('leituras-hoje').textContent   = json.leituras_hoje ?? '0';

        renderEstacoes(estacoes);
    } catch (err) {
        document.getElementById('estacoes-lista').innerHTML = '<div class="loading-msg">Erro ao carregar dados.</div>';
    }
}

async function alterarStatus(id, novoStatus) {
    if (!podeStatus) {
        mostrarAvisoPermissao('Alterar status requer nível Admin ou superior.');
        return;
    }
    try {
        const res = await fetch(`/api/estacoes/${id}/status`, {
            method:  'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ status: novoStatus })
        });
        if (!res.ok) {
            const json = await res.json();
            mostrarAvisoPermissao(json.erro || 'Erro ao atualizar status.');
            return;
        }
        carregarSensores();
    } catch (e) { mostrarAvisoPermissao('Erro de conexão.'); }
}

document.getElementById('busca-input').addEventListener('input', function() {
    const termo = this.value.toLowerCase();
    document.querySelectorAll('.estacao-card').forEach(card => {
        const nome = card.querySelector('.estacao-nome-row strong')?.textContent.toLowerCase() ?? '';
        card.style.display = nome.includes(termo) ? '' : 'none';
    });
});

// ══════════════════════════════════════════════════════
// MODAL — CRIAR ESTAÇÃO
// ══════════════════════════════════════════════════════
function tentarCriarEstacao() {
    if (!temPermissao('admin')) {
        mostrarAvisoPermissao('Criar estações requer nível Admin ou superior.');
        return;
    }
    abrirModal();
}

function abrirModal() {
    document.getElementById('modal-estacao').classList.add('aberto');
    document.getElementById('m-nome').focus();
}

function fecharModal() {
    document.getElementById('modal-estacao').classList.remove('aberto');
    ['m-nome','m-desc','m-lat','m-lng'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('m-intervalo').value = '5';
    const err = document.getElementById('modal-erro');
    if (err) { err.textContent = ''; err.style.display = 'none'; }
}

document.getElementById('modal-estacao')?.addEventListener('click', function(e) {
    if (e.target === this) fecharModal();
});

async function salvarEstacao() {
    const nome      = document.getElementById('m-nome').value.trim();
    const descricao = document.getElementById('m-desc').value.trim();
    const latitude  = document.getElementById('m-lat').value;
    const longitude = document.getElementById('m-lng').value;
    const intervalo = document.getElementById('m-intervalo').value;
    const err       = document.getElementById('modal-erro');
    const btn       = document.getElementById('btn-salvar-estacao');

    if (!nome) {
        err.textContent   = 'O nome da estação é obrigatório.';
        err.style.display = 'block';
        document.getElementById('m-nome').focus();
        return;
    }

    btn.disabled    = true;
    btn.textContent = 'Salvando...';

    try {
        const res  = await fetch('/api/estacoes', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ nome, descricao, latitude, longitude, intervalo })
        });
        const json = await res.json();

        if (res.ok) { fecharModal(); carregarSensores(); }
        else { err.textContent = json.erro || 'Erro ao salvar.'; err.style.display = 'block'; }
    } catch (e) {
        err.textContent   = 'Erro de conexão.';
        err.style.display = 'block';
    } finally {
        btn.disabled    = false;
        btn.textContent = 'Salvar Estação';
    }
}

// ══════════════════════════════════════════════════════
// MODAL — EDITAR ESTAÇÃO
// ══════════════════════════════════════════════════════
function abrirEditar(estacao) {
    document.getElementById('editar-id').value        = estacao.id;
    document.getElementById('editar-nome').value      = estacao.nome      || '';
    document.getElementById('editar-desc').value      = estacao.descricao || '';
    document.getElementById('editar-lat').value       = estacao.latitude  || '';
    document.getElementById('editar-lng').value       = estacao.longitude || '';
    document.getElementById('editar-intervalo').value = Math.round((estacao.intervalo_leitura || 5000) / 1000);
    document.getElementById('editar-sub').textContent = `ID: ${estacao.id} — ${estacao.nome}`;
    document.getElementById('editar-erro').style.display = 'none';

    const semPermissao = document.getElementById('editar-info-permissao');
    const btnSalvar    = document.getElementById('btn-salvar-editar');

    if (!podeEditar) {
        semPermissao.style.display = 'flex';
        btnSalvar.style.display    = 'none';
        ['editar-nome','editar-desc','editar-lat','editar-lng','editar-intervalo']
            .forEach(id => document.getElementById(id).disabled = true);
    } else {
        semPermissao.style.display = 'none';
        btnSalvar.style.display    = 'flex';
        ['editar-nome','editar-desc','editar-lat','editar-lng','editar-intervalo']
            .forEach(id => document.getElementById(id).disabled = false);
    }

    document.getElementById('modal-editar').classList.add('aberto');
    if (podeEditar) setTimeout(() => document.getElementById('editar-nome').focus(), 100);
}

function fecharEditar() {
    document.getElementById('modal-editar').classList.remove('aberto');
}

document.getElementById('modal-editar')?.addEventListener('click', function(e) {
    if (e.target === this) fecharEditar();
});

async function salvarEdicao() {
    const id        = document.getElementById('editar-id').value;
    const nome      = document.getElementById('editar-nome').value.trim();
    const descricao = document.getElementById('editar-desc').value.trim();
    const latitude  = document.getElementById('editar-lat').value;
    const longitude = document.getElementById('editar-lng').value;
    const intervalo = document.getElementById('editar-intervalo').value;
    const erro      = document.getElementById('editar-erro');
    const btn       = document.getElementById('btn-salvar-editar');

    if (!nome) {
        erro.textContent   = 'O nome da estação é obrigatório.';
        erro.style.display = 'block';
        document.getElementById('editar-nome').focus();
        return;
    }

    btn.disabled    = true;
    btn.textContent = 'Salvando...';

    try {
        const res = await fetch(`/api/estacoes/${id}`, {
            method:  'PUT',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ nome, descricao, latitude, longitude })
        });

        if (!res.ok) {
            const json = await res.json();
            erro.textContent   = json.erro || 'Erro ao salvar.';
            erro.style.display = 'block';
            return;
        }

        // atualiza intervalo separado
        await fetch(`/api/estacoes/${id}/intervalo`, {
            method:  'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ intervalo })
        });

        fecharEditar();
        carregarSensores();
    } catch (e) {
        erro.textContent   = 'Erro de conexão.';
        erro.style.display = 'block';
    } finally {
        btn.disabled    = false;
        btn.textContent = 'Salvar Alterações';
    }
}

// ══════════════════════════════════════════════════════
// MODAL — EXCLUIR ESTAÇÃO
// ══════════════════════════════════════════════════════
let estacaoParaExcluir = null;

function abrirModalExcluir(id, nome) {
    estacaoParaExcluir = id;
    document.getElementById('excluir-nome-estacao').textContent = nome ? `Excluindo: ${nome}` : 'Esta ação não pode ser desfeita';
    document.getElementById('excluir-erro').style.display = 'none';
    document.getElementById('modal-excluir').classList.add('aberto');
}

function fecharExcluir() {
    estacaoParaExcluir = null;
    document.getElementById('modal-excluir').classList.remove('aberto');
}

document.getElementById('modal-excluir')?.addEventListener('click', function(e) {
    if (e.target === this) fecharExcluir();
});

async function confirmarExclusao() {
    const err = document.getElementById('excluir-erro');
    const btn = document.getElementById('btn-confirmar-excluir');

    btn.disabled    = true;
    btn.textContent = 'Excluindo...';

    try {
        const res  = await fetch(`/api/estacoes/${estacaoParaExcluir}`, {
            method:  'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({})
        });
        const json = await res.json();

        if (res.ok) { fecharExcluir(); carregarSensores(); }
        else { err.textContent = json.erro || 'Erro ao excluir.'; err.style.display = 'block'; }
    } catch (e) {
        err.textContent   = 'Erro de conexão.';
        err.style.display = 'block';
    } finally {
        btn.disabled    = false;
        btn.textContent = '🗑 Confirmar Exclusão';
    }
}

// ══════════════════════════════════════════════════════
// ALERTAS
// ══════════════════════════════════════════════════════
let alertas = JSON.parse(localStorage.getItem('airguard_alertas') || '[]');
const SNOME = { temperatura:'Temperatura', umidade:'Umidade', gases:'Gases MQ135', CO:'CO MQ7' };
const COND  = { maior:'>', menor:'<' };

function renderAlertas() {
    const lista = document.getElementById('alertas-lista');
    if (alertas.length === 0) {
        lista.innerHTML = '<div style="text-align:center;color:#94a3b8;font-size:13px;font-weight:600;padding:16px;">Nenhum alerta configurado.</div>';
        return;
    }
    lista.innerHTML = alertas.map((a, i) => `
        <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-radius:10px;margin-bottom:8px;background:${a.severidade==='critico'?'#fff5f5':'#fffbeb'};border-left:4px solid ${a.severidade==='critico'?'#ef4444':'#f59e0b'};">
            <div style="display:flex;align-items:center;gap:10px;">
                <span style="font-size:18px;">${a.severidade==='critico'?'🔴':'⚠️'}</span>
                <div>
                    <div style="font-size:13px;font-weight:800;color:#1e3a5f;">${a.desc||SNOME[a.sensor]}</div>
                    <div style="font-size:12px;color:#64748b;font-weight:600;">${SNOME[a.sensor]} ${COND[a.cond]} ${a.valor}</div>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:8px;">
                <button onclick="toggleAlerta(${i})" style="background:#fff;border:1px solid #e2e8f0;color:#64748b;font-family:Nunito,sans-serif;font-size:12px;font-weight:700;padding:4px 10px;border-radius:6px;cursor:pointer;">${a.ativo?'Desativar':'Ativar'}</button>
                <button onclick="removerAlerta(${i})" style="background:#fff;border:1px solid #fee2e2;color:#ef4444;font-family:Nunito,sans-serif;font-size:12px;font-weight:800;padding:4px 10px;border-radius:6px;cursor:pointer;">✕</button>
            </div>
        </div>`).join('');
}

function salvarAlerta() {
    const valor = parseFloat(document.getElementById('al-valor').value);
    if (isNaN(valor)) { alert('Informe um valor numérico.'); return; }
    alertas.push({
        sensor: document.getElementById('al-sensor').value,
        cond:   document.getElementById('al-cond').value,
        valor,
        severidade: document.getElementById('al-sev').value,
        desc:   document.getElementById('al-desc').value.trim(),
        ativo:  true
    });
    localStorage.setItem('airguard_alertas', JSON.stringify(alertas));
    renderAlertas();
    document.getElementById('form-alerta').style.display = 'none';
    document.getElementById('al-valor').value = '';
    document.getElementById('al-desc').value  = '';
}

function removerAlerta(i) { alertas.splice(i,1); localStorage.setItem('airguard_alertas', JSON.stringify(alertas)); renderAlertas(); }
function toggleAlerta(i)  { alertas[i].ativo = !alertas[i].ativo; localStorage.setItem('airguard_alertas', JSON.stringify(alertas)); renderAlertas(); }

// fecha ESC
document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
        fecharModal();
        fecharEditar();
        fecharExcluir();
    }
});


function conectarWS() {
    const ws = new WebSocket('ws://' + location.host);

    ws.onmessage = (e) => {
        const msg = JSON.parse(e.data);

        if (msg.tipo === 'leitura') {
            // pega o valor atual do card e soma +1
            const el = document.getElementById('leituras-hoje');
            const atual = parseInt(el.textContent) || 0;
            el.textContent = atual + 1;
        }
    };

    ws.onclose = () => setTimeout(conectarWS, 3000); // reconecta se cair
}

conectarWS();







carregarSensores();
renderAlertas();
</script>

</body>
