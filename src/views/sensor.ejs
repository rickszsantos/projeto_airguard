}






//carregar a tela de cadastrar estações
function abrirModal() {
    document.getElementById('modal-estacao').classList.add('aberto');
    document.getElementById('m-nome').focus();
}

function fecharModal() {
    document.getElementById('modal-estacao').classList.remove('aberto');
    // limpa os campos
    document.getElementById('m-nome').value      = '';
    document.getElementById('m-desc').value      = '';
    document.getElementById('m-lat').value       = '';
    document.getElementById('m-lng').value       = '';
    document.getElementById('m-intervalo').value = '5';
    // esconde o erro
    const err = document.getElementById('modal-erro');
    if (err) { err.textContent = ''; err.style.display = 'none'; }
}

// fecha ao clicar no overlay
document.getElementById('modal-estacao')?.addEventListener('click', function(e) {
    if (e.target === this) fecharModal();
});

// fecha com ESC
document.addEventListener('keydown', e => {
    if (e.key === 'Escape') fecharModal();
});

async function salvarEstacao() {
    const nome      = document.getElementById('m-nome').value.trim();
    const descricao = document.getElementById('m-desc').value.trim();
    const latitude  = document.getElementById('m-lat').value;
    const longitude = document.getElementById('m-lng').value;
    const intervalo = document.getElementById('m-intervalo').value;

    // validação
    if (!nome) {
        const err = document.getElementById('modal-erro');
        err.textContent    = 'O nome da estação é obrigatório.';
        err.style.display  = 'block';
        document.getElementById('m-nome').focus();
        return;
    }

    // desabilita o botão para evitar duplo clique
    const btn = document.getElementById('btn-salvar-estacao');
    if (btn) { btn.disabled = true; btn.textContent = 'Salvando...'; }

    try {
        const res = await fetch('/api/estacoes', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ nome, descricao, latitude, longitude, intervalo })
});

        const json = await res.json();

        if (res.ok) {
            fecharModal();
            carregarSensores(); // recarrega a lista sem recarregar a página
        } else {
            const err = document.getElementById('modal-erro');
            err.textContent   = json.erro || 'Erro ao salvar estação.';
            err.style.display = 'block';
        }
    } catch (e) {
        console.error(e);
        const err = document.getElementById('modal-erro');
        err.textContent   = 'Erro de conexão. Tente novamente.';
        err.style.display = 'block';
    } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Salvar Estação'; }
    }
}



function excluirEstacao(id) {
    confirmarSuperAdmin({
        titulo: 'Excluir Estação?',
        texto: 'Todos os sensores e leituras serão removidos.',
        btnLabel: '🗑 Excluir',
        onConfirm: async (senha) => {
            await apiProtegida(`/api/estacoes/${id}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ senha_superadmin: senha })
            });
            carregarSensores();
        }
    });
}




